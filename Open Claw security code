import test from 'node:test';
import assert from 'node:assert/strict';
import * as fs from 'fs';
import * as os from 'os';
import * as path from 'path';
import * as http from 'http';
import { createEglServer } from '../src/server';
import { dispatchViaEgl } from '../src/dispatch';
import { generateEd25519KeyPair, issueDlc } from '../src/capability';
 
function listen(server: any): Promise<number> {
  return new Promise((resolve, reject) => {
    server.once('error', reject);
    server.listen(0, '127.0.0.1', () => {
      const address = server.address();
      if (!address || typeof address === 'string') {
        reject(new Error('Server address unavailable'));
        return;
      }
      resolve(address.port);
    });
  });
}
 
function closeServer(server: any): Promise<void> {
  return new Promise((resolve, reject) => server.close((error) => error ? reject(error) : resolve()));
}
 
test('dispatchViaEgl mints a bound envelope and forwards HTTP through EGL', async () => {
  const upstream = http.createServer((req, res) => {
    const bodyChunks: Buffer[] = [];
    req.on('data', (chunk) => bodyChunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(chunk)));
    req.on('end', () => {
      res.writeHead(200, { 'content-type': 'application/json' });
      res.end(JSON.stringify({
        method: req.method,
        url: req.url,
        bodyText: Buffer.concat(bodyChunks).toString('utf8')
      }));
    });
  });
 
  const dlcKeys = generateEd25519KeyPair();
  const gelKeys = generateEd25519KeyPair();
  const upstreamPort = await listen(upstream);
  const telemetryPath = path.join(os.tmpdir(), `hydra-egl-${Date.now()}-${Math.random()}.jsonl`);
  const { server: egl } = createEglServer({
    port: 0,
    dlcPublicKey: dlcKeys.publicKeyPem,
    envelopePublicKey: gelKeys.publicKeyPem,
    telemetryPath,
    defaultAllowedHosts: []
  });
  const eglPort = await listen(egl);
 
  try {
    const signedDlc = issueDlc(dlcKeys.privateKeyPem, {
      subject: 'agent-dispatch',
      entityId: 'hydra',
      entityRole: 'operator',
      modelId: 'openclaw',
      provider: 'local',
      governanceProfile: 'strict',
      allowedHosts: ['127.0.0.1'],
      allowedMethods: ['POST'],
      allowedOperations: ['http_forward'],
      pathPrefixes: ['/dispatch-ok']
    });
 
    const result = await dispatchViaEgl({
      url: `http://127.0.0.1:${upstreamPort}/dispatch-ok?x=1`,
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ hello: 'world' }),
      proxy: { host: '127.0.0.1', port: eglPort },
      dlcToken: signedDlc.token,
      dlcVerifier: { publicKeyPem: dlcKeys.publicKeyPem },
      gelSigner: { privateKeyPem: gelKeys.privateKeyPem, ttlSeconds: 30 },
      requestId: 'dispatch-test-1'
    });
 
    assert.equal(result.statusCode, 200);
    assert.equal(result.requestId, 'dispatch-test-1');
    assert.equal(result.via, 'http_forward');
    const parsed = JSON.parse(result.body.toString('utf8'));
    assert.equal(parsed.method, 'POST');
    assert.equal(parsed.url, '/dispatch-ok?x=1');
    assert.match(parsed.bodyText, /hello/);
 
    const telemetry = fs.readFileSync(telemetryPath, 'utf8');
    assert.match(telemetry, /dispatch-test-1/);
  } finally {
    await closeServer(egl);
    await closeServer(upstream);
    if (fs.existsSync(telemetryPath)) fs.unlinkSync(telemetryPath);
  }
});
 
