import * as http from 'http';
import * as https from 'https';
import * as tls from 'tls';
import { mintEnvelope } from './envelope';
import { verifyDlc } from './capability';
import { DispatchRequest, DispatchResponse, DlcCapability, EnforcementInput } from './types';
 
function normalizeHeaders(headers: Record<string, string> = {}): Record<string, string> {
  const output: Record<string, string> = {};
  for (const [key, value] of Object.entries(headers)) {
    output[key] = value;
  }
  return output;
}
 
function resolveDlc(request: DispatchRequest): DlcCapability | undefined {
  if (request.dlc) return request.dlc;
  if (request.dlcVerifier?.publicKeyPem || request.dlcVerifier?.sharedSecret) {
    return verifyDlc(request.dlcToken, request.dlcVerifier);
  }
  return undefined;
}
 
function resolveSigning(request: DispatchRequest): { algorithm: 'EdDSA' | 'HS256'; signingKey: string } {
  if (request.gelSigner.privateKeyPem) {
    return { algorithm: 'EdDSA', signingKey: request.gelSigner.privateKeyPem };
  }
  if (request.gelSigner.sharedSecret) {
    return { algorithm: 'HS256', signingKey: request.gelSigner.sharedSecret };
  }
  throw new Error('GEL signer not configured');
}
 
function collectResponse(response: any, requestId: string, envelopeToken: string, envelopePayload: any, via: 'http_forward' | 'https_connect'): Promise<DispatchResponse> {
  return new Promise((resolve, reject) => {
    const chunks: Buffer[] = [];
    response.on('data', (chunk) => chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(chunk)));
    response.on('end', () => {
      resolve({
        statusCode: response.statusCode ?? 0,
        headers: response.headers as Record<string, string | string[] | undefined>,
        body: Buffer.concat(chunks),
        requestId,
        envelopeToken,
        envelopePayload,
        via
      });
    });
    response.on('error', reject);
  });
}
 
function buildInput(url: URL, method: string, operation?: string): EnforcementInput {
  const isHttps = url.protocol === 'https:';
  return {
    destinationHost: url.hostname,
    destinationPort: url.port ? parseInt(url.port, 10) : (isHttps ? 443 : 80),
    method: isHttps ? 'CONNECT' : method.toUpperCase(),
    operation: operation ?? (isHttps ? 'https_connect' : 'http_forward'),
    path: isHttps ? undefined : `${url.pathname}${url.search}`
  };
}
 
async function createTlsConnectionViaProxy(request: DispatchRequest, input: EnforcementInput, envelopeToken: string, targetUrl: URL): Promise<any> {
  return new Promise((resolve, reject) => {
    const connectRequest = http.request({
      host: request.proxy.host,
      port: request.proxy.port,
      method: 'CONNECT',
      path: `${input.destinationHost}:${input.destinationPort}`,
      headers: {
        'Proxy-Authorization': `Bearer ${request.dlcToken}`,
        'x-hydra-envelope': envelopeToken
      }
    });
 
    const timeoutMs = request.timeoutMs ?? 10000;
    connectRequest.setTimeout(timeoutMs, () => connectRequest.destroy(new Error('Proxy CONNECT timed out')));
    connectRequest.on('error', reject);
    connectRequest.on('connect', (res, socket) => {
      if ((res.statusCode ?? 0) !== 200) {
        socket.destroy();
        reject(new Error(`Proxy CONNECT denied with status ${res.statusCode ?? 0}`));
        return;
      }
 
      const tlsSocket = tls.connect({
        socket,
        servername: targetUrl.hostname,
        rejectUnauthorized: request.rejectUnauthorized ?? true
      }, () => resolve(tlsSocket));
      tlsSocket.on('error', reject);
    });
    connectRequest.end();
  });
}
 
export async function dispatchViaEgl(request: DispatchRequest): Promise<DispatchResponse> {
  const targetUrl = new URL(request.url);
  const method = (request.method ?? 'GET').toUpperCase();
  const input = buildInput(targetUrl, method, request.operation);
  const dlc = resolveDlc(request);
  const { algorithm, signingKey } = resolveSigning(request);
  const signedEnvelope = mintEnvelope(signingKey, input, dlc, {
    ttlSeconds: request.gelSigner.ttlSeconds ?? 60,
    keyId: request.gelSigner.keyId,
    requestId: request.requestId
  }, algorithm);
  const body = typeof request.body === 'string' ? Buffer.from(request.body) : request.body;
 
  if (targetUrl.protocol === 'http:') {
    const headers = normalizeHeaders(request.headers);
    if (body && headers['content-length'] === undefined && headers['Content-Length'] === undefined) {
      headers['content-length'] = String(body.length);
    }
 
    return await new Promise<DispatchResponse>((resolve, reject) => {
      const proxyRequest = http.request({
        host: request.proxy.host,
        port: request.proxy.port,
        method,
        path: targetUrl.toString(),
        headers: {
          ...headers,
          host: targetUrl.host,
          'x-hydra-dlc': request.dlcToken,
          'x-hydra-envelope': signedEnvelope.token
        }
      }, async (response) => {
        try {
          resolve(await collectResponse(response, signedEnvelope.payload.requestId, signedEnvelope.token, signedEnvelope.payload, 'http_forward'));
        } catch (error) {
          reject(error);
        }
      });
 
      proxyRequest.setTimeout(request.timeoutMs ?? 10000, () => proxyRequest.destroy(new Error('Proxy request timed out')));
      proxyRequest.on('error', reject);
      if (body) proxyRequest.write(body);
      proxyRequest.end();
    });
  }
 
  if (targetUrl.protocol !== 'https:') {
    throw new Error(`Unsupported target protocol: ${targetUrl.protocol}`);
  }
 
  return await new Promise<DispatchResponse>((resolve, reject) => {
    const headers = normalizeHeaders(request.headers);
    if (body && headers['content-length'] === undefined && headers['Content-Length'] === undefined) {
      headers['content-length'] = String(body.length);
    }
    headers.host = targetUrl.host;
 
    const httpsRequest = https.request({
      host: targetUrl.hostname,
      port: targetUrl.port ? parseInt(targetUrl.port, 10) : 443,
      method,
      path: `${targetUrl.pathname}${targetUrl.search}`,
      headers,
      agent: false,
      rejectUnauthorized: request.rejectUnauthorized ?? true,
      createConnection: (_options: any, callback: any) => {
        createTlsConnectionViaProxy(request, input, signedEnvelope.token, targetUrl)
          .then((socket) => callback(null, socket))
          .catch((error) => callback(error));
        return undefined as any;
      }
    } as any, async (response) => {
      try {
        resolve(await collectResponse(response, signedEnvelope.payload.requestId, signedEnvelope.token, signedEnvelope.payload, 'https_connect'));
      } catch (error) {
        reject(error);
      }
    });
 
    httpsRequest.setTimeout(request.timeoutMs ?? 15000, () => httpsRequest.destroy(new Error('HTTPS dispatch timed out')));
    httpsRequest.on('error', reject);
    if (body) httpsRequest.write(body);
    httpsRequest.end();
  });
}
 
