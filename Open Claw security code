      subject:         'openclaw-agent',
      createdAt,
      expiresAt,
    },
    ENV_PRIVATE_KEY_FILE,
    ENV_SIGNING_SECRET,
  );
 
  return { dlcToken, envelopeToken, jti, envelopeId: envId };
}
 
