#!/bin/bash
# =============================================================================
# HYDRA KERNEL — Pack Utility
# Builds the versioned zip with prior constitutional versions archived
#
# The problem this solves:
#   The VCKB requires versioning — old constitutional docs must not disappear.
#   But V1, V2, V3... accumulate and the zip gets unwieldy.
#   Solution: keep current files uncompressed, compress older versions into
#   prior_archive/constitutional_history.zip inside the main zip.
#   Nothing is lost. Old versions are reachable. The view is clean.
#
# Usage:
#   ./pack.sh [version] [date]
#   ./pack.sh 0.3.8 20260323
#   (defaults to reading VERSION_MANIFEST.json for version/date)
#
# Output:
#   hydra_gel_v{VERSION}_{DATE}.zip in the parent directory
# =============================================================================
 
set -euo pipefail
 
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"
 
# --- Read version from manifest if not passed as args ---
if [ $# -ge 2 ]; then
  GEL_VERSION="$1"
  DATE_STAMP="$2"
else
  GEL_VERSION=$(python3 -c "import json; m=json.load(open('VERSION_MANIFEST.json')); print(m['gel_version'])" 2>/dev/null || echo "0.0.0")
  DATE_STAMP=$(date +%Y%m%d)
fi
 
ZIP_NAME="hydra_gel_v${GEL_VERSION}_${DATE_STAMP}.zip"
ARCHIVE_DIR="prior_archive"
CONSTITUTIONAL_HISTORY="$ARCHIVE_DIR/constitutional_history.zip"
DOCS_DIR="current/vckb/docs"
 
echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║   HYDRA KERNEL — Pack Utility                    ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""
echo "  Building: $ZIP_NAME"
echo "  Strategy: current files uncompressed, prior versions archived"
echo ""
 
# --- Step 1: Create prior_archive directory ---
mkdir -p "$ARCHIVE_DIR"
 
# --- Step 2: Find constitutional docs to archive ---
# Keep: the two most recent (current + one prior)
# Archive: everything older than that
# "Most recent" = highest version number by filename sort
 
CONSTITUTIONAL_DOCS=$(ls "$DOCS_DIR"/CONSTITUTIONAL_MASTER_OUTLINE*.md 2>/dev/null | sort -V)
DOC_COUNT=$(echo "$CONSTITUTIONAL_DOCS" | wc -l)
echo "  Constitutional docs found: $DOC_COUNT"
 
if [ "$DOC_COUNT" -gt 2 ]; then
  # Archive everything except the two most recent
  TO_ARCHIVE=$(echo "$CONSTITUTIONAL_DOCS" | head -n $((DOC_COUNT - 2)))
  echo ""
  echo "  Archiving older constitutional versions:"
  for f in $TO_ARCHIVE; do
    echo "    → $(basename $f)"
  done
 
  # Create or update the constitutional history archive
  if [ -n "$TO_ARCHIVE" ]; then
    # Add to history zip (create if not exists)
    zip -j "$CONSTITUTIONAL_HISTORY" $TO_ARCHIVE 2>/dev/null || true
    echo "  Archived to: $CONSTITUTIONAL_HISTORY"
  fi
else
  echo "  Only $DOC_COUNT constitutional doc(s) — nothing to archive yet"
fi
 
echo ""
 
# --- Step 3: Build the main zip ---
# Include: everything at current level + current/ + prior/ (not the docs being archived)
# Include: prior_archive/ (the compressed history)
# Exclude: the archived docs from the main zip (they're in constitutional_history.zip now)
 
echo "  Building main zip..."
 
# Get list of docs to EXCLUDE from main zip (they're in the archive)
if [ "$DOC_COUNT" -gt 2 ]; then
  ARCHIVED_DOCS=$(echo "$CONSTITUTIONAL_DOCS" | head -n $((DOC_COUNT - 2)))
else
  ARCHIVED_DOCS=""
fi
 
# Build exclusion args
EXCLUDE_ARGS=""
for f in $ARCHIVED_DOCS; do
  EXCLUDE_ARGS="$EXCLUDE_ARGS --exclude=$(basename $f)"
done
 
# Create the zip
ZIP_PATH="../$ZIP_NAME"
rm -f "$ZIP_PATH"
 
zip -r "$ZIP_PATH" . \
  --exclude="*.DS_Store" \
  --exclude=".git/*" \
  --exclude="node_modules/*" \
  --exclude="build/*" \
  --exclude="dist/*" \
  --exclude="*.log" \
  --exclude="pack.sh.bak" \
  2>/dev/null
 
echo "  Built: $ZIP_PATH"
echo ""
 
# --- Step 4: Report ---
ZIP_SIZE=$(du -sh "$ZIP_PATH" 2>/dev/null | cut -f1 || echo "?")
echo "  Size: $ZIP_SIZE"
echo ""
echo "  Contents:"
echo "    Uncompressed (top level): MASTER_README, CHANGELOG, VERSION_MANIFEST, etc."
echo "    Uncompressed (current/):  GEL source, VCKB docs (current + one prior)"
echo "    Compressed (prior/):      Prior VCKB constitution, old manifests"
if [ -f "$CONSTITUTIONAL_HISTORY" ]; then
  HIST_COUNT=$(zipinfo -1 "$CONSTITUTIONAL_HISTORY" 2>/dev/null | wc -l || echo "?")
  echo "    Archived (prior_archive/constitutional_history.zip): $HIST_COUNT versions"
fi
echo ""
echo "  To access archived versions:"
echo "    unzip $ARCHIVE_DIR/constitutional_history.zip -d /tmp/constitutional_history/"
echo ""
echo "  VCKB principle: nothing deleted, everything reachable, view is clean."
echo ""
echo "Done."
 
