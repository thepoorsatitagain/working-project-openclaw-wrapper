  if (req.path === '/gel/app-pipeline' && req.method === 'POST') {
    const pipelineCheck = interpretEnvelope(envelope, OPERATIONS.APP_PIPELINE_SUBMIT);
 
    if (!pipelineCheck.permitted) {
      logEvent('OPERATION_DENIED', requestId, {
        operation: OPERATIONS.APP_PIPELINE_SUBMIT,
        reason:    pipelineCheck.reason,
      });
      res.status(403).json({
        error:     'GEL_OPERATION_NOT_PERMITTED',
        requestId,
        reason:    pipelineCheck.reason,
        replay:    `/gel/replay/${requestId}`,
      });
      return;
    }
 
    const { problemStatement, domain } = (req as Request).body ?? {};
 
    if (!problemStatement || typeof problemStatement !== 'string') {
      res.status(400).json({
        error:   'GEL_PIPELINE_BAD_REQUEST',
        message: 'problemStatement (string) required in request body',
      });
      return;
    }
 
    // Check pipeline readiness (all 5 VCKB docs loaded)
    if (!pipelineReady) {
      logEvent('DENIED', requestId, {
        reason:  'APP pipeline not ready — not all VCKB documents are loaded',
        loaded:  vckbResult.documents.map(d => d.id),
        missing: vckbResult.errors,
      });
      res.status(503).json({
        error:         'GEL_PIPELINE_NOT_READY',
        requestId,
        message:       'APP pipeline requires all VCKB documents. Some are missing.',
        docsLoaded:    vckbResult.documents.map(d => d.id),
        docsMissing:   vckbResult.errors,
        fix:           'Add APP_paper.md, patent_ai_control_1.md, patent_ai_control_2.md to current/vckb/docs/',
        replay:        `/gel/replay/${requestId}`,
      });
