import { randomUUID } from 'crypto';
import { TelemetryEvent, TelemetryEventType, ExecutionEnvelope } from './types';
 
const LOG_DIR  = path.resolve(process.cwd(), 'logs');
const LOG_FILE = path.join(LOG_DIR, 'telemetry.jsonl');
 
function ensureLogDir(): void {
  if (!fs.existsSync(LOG_DIR)) {
    fs.mkdirSync(LOG_DIR, { recursive: true });
  }
}
 
// -----------------------------------------------------------------------------
// Write — append-only. The only write operation on this log.
// -----------------------------------------------------------------------------
export function logEvent(
  type: TelemetryEventType,
  requestId: string,
  data: unknown
): TelemetryEvent {
  ensureLogDir();
 
  const event: TelemetryEvent = {
    eventId:   randomUUID(),
    timestamp: new Date().toISOString(),
    type,
    requestId,
    data,
  };
 
  // O_APPEND flag — OS-level atomicity for concurrent writes
  fs.appendFileSync(LOG_FILE, JSON.stringify(event) + '\n', {
    encoding: 'utf8',
    flag: 'a',
  });
 
  return event;
}
 
// -----------------------------------------------------------------------------
// Read — hardened. One malformed line does not crash the reader.
// Constitutional Invariant 11: no silent degradation — malformed lines logged.
// -----------------------------------------------------------------------------
export function readLog(): TelemetryEvent[] {
  ensureLogDir();
  if (!fs.existsSync(LOG_FILE)) return [];
 
  const lines  = fs.readFileSync(LOG_FILE, 'utf8').split('\n').filter(Boolean);
  const events: TelemetryEvent[] = [];
 
  for (let i = 0; i < lines.length; i++) {
    try {
      events.push(JSON.parse(lines[i]) as TelemetryEvent);
    } catch {
      // Malformed line — log it explicitly, do not crash (Invariant 11)
      events.push({
        eventId:   randomUUID(),
        timestamp: new Date().toISOString(),
        type:      'ERROR',
        requestId: 'UNKNOWN',
        data:      { malformedLine: i + 1, content: lines[i].slice(0, 100) },
      });
    }
  }
 
  return events;
}
 
export function readLogForRequest(requestId: string): TelemetryEvent[] {
  return readLog().filter((e) => e.requestId === requestId);
}
 
// -----------------------------------------------------------------------------
// getDecisionTrace — reconstruct the full governance decision for replay.
//
// Returns everything needed to verify a past authorization decision:
//   - The original request details
//   - The policy rule that was matched
//   - The envelope that was issued (or null if DENY)
//   - The final decision
//
// This is what makes the claim replayable.
// -----------------------------------------------------------------------------
export interface DecisionTrace {
  requestId:        string;
  requestPath:      string | null;
  requestMethod:    string | null;
  policyRuleId:     string | null;
  decision:         'ALLOW' | 'DENY' | null;
  decisionReason:   string | null;
  decisionTimestamp: string | null;
  envelopeSnapshot: ExecutionEnvelope | null;
  eventCount:       number;
  replayable:       boolean;
}
 
export function getDecisionTrace(requestId: string): DecisionTrace {
  const events = readLogForRequest(requestId);
 
  const trace: DecisionTrace = {
    requestId,
    requestPath:       null,
    requestMethod:     null,
    policyRuleId:      null,
    decision:          null,
    decisionReason:    null,
    decisionTimestamp: null,
    envelopeSnapshot:  null,
    eventCount:        events.length,
    replayable:        false,
  };
 
  for (const event of events) {
    const d = event.data as Record<string, unknown>;
 
    if (event.type === 'REQUEST_INTERCEPTED') {
      trace.requestPath   = (d.path   as string) ?? null;
      trace.requestMethod = (d.method as string) ?? null;
    }
 
    if (event.type === 'POLICY_EVALUATED') {
      trace.policyRuleId = (d.ruleId as string) ?? null;
    }
 
    if (event.type === 'ENVELOPE_CREATED') {
      // Envelope snapshot stored at creation time
      trace.envelopeSnapshot = (d.envelope as ExecutionEnvelope) ?? null;
    }
 
    if (event.type === 'DECISION_MADE') {
      trace.decision          = (d.result as 'ALLOW' | 'DENY') ?? null;
      trace.decisionReason    = (d.reason as string) ?? null;
      trace.decisionTimestamp = event.timestamp;
    }
  }
 
  // Replayable if we have enough data to reconstruct the decision
  trace.replayable =
    trace.decision !== null &&
    trace.requestPath !== null &&
    trace.requestMethod !== null &&
    (trace.decision === 'DENY' || trace.envelopeSnapshot !== null);
 
  return trace;
}
 
