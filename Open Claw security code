import * as fs from 'fs';
import * as path from 'path';
import { VCKBDocument } from './vckb_loader';
 
export type OutputGateVerdict = 'ALLOW' | 'WARN' | 'DENY';
 
export interface OutputGateFinding {
  ruleId: string;
  severity: 'WARN' | 'DENY';
  message: string;
  evidence?: string;
}
 
export interface OutputGateResult {
  verdict: OutputGateVerdict;
  findings: OutputGateFinding[];
  checkedAt: string;
  checkedRules: string[];
  textPreview: string;
  criticalDocsPresent: boolean;
}
 
export interface OutputGateProfile {
  ruleZeroLoaded: boolean;
  constitutionLoaded: boolean;
  requiredDocIds: string[];
  loadedDocIds: string[];
}
 
const RULE_ZERO_PATH = path.resolve(process.cwd(), '../../RULE_ZERO.md');
 
export function buildOutputGateProfile(documents: VCKBDocument[]): OutputGateProfile {
  const loadedDocIds = documents.map((doc) => doc.id);
  return {
    ruleZeroLoaded: fs.existsSync(RULE_ZERO_PATH),
    constitutionLoaded: loadedDocIds.includes('CONSTITUTION'),
    requiredDocIds: ['CONSTITUTION'],
    loadedDocIds,
  };
}
 
export function extractCandidateText(body: string): string {
  try {
    const parsed = JSON.parse(body) as unknown;
    const parts: string[] = [];
    walk(parsed, parts);
    const joined = parts.join('\n').trim();
    return joined.length > 0 ? joined : body;
  } catch {
    return body;
  }
}
 
function walk(value: unknown, parts: string[]): void {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (trimmed.length > 0) parts.push(trimmed);
    return;
  }
  if (Array.isArray(value)) {
    for (const item of value) walk(item, parts);
    return;
  }
  if (value && typeof value === 'object') {
    for (const [key, child] of Object.entries(value as Record<string, unknown>)) {
      if ((key === 'text' || key === 'content' || key === 'output_text') && typeof child === 'string') {
        const trimmed = child.trim();
        if (trimmed.length > 0) parts.push(trimmed);
      }
      walk(child, parts);
    }
  }
}
 
export function evaluateOutputAgainstVCKB(
  candidateText: string,
  profile: OutputGateProfile,
): OutputGateResult {
  const findings: OutputGateFinding[] = [];
  const checkedRules = [
    'GEL-OUT-001_VCKB_REQUIRED',
    'GEL-OUT-002_RULE_ZERO_NO_HISTORY_ERASURE',
    'GEL-OUT-003_FAIL_CLOSED_ON_MISSING_AUTHORITY',
  ];
 
  const normalized = normalizeWhitespace(candidateText);
 
  if (!profile.constitutionLoaded) {
    findings.push({
      ruleId: 'GEL-OUT-001_VCKB_REQUIRED',
      severity: 'DENY',
      message: 'Critical VCKB documents are not loaded; output cannot be released as verified.',
    });
  }
 
  const historyErase = /(delete|erase|overwrite|replace|discard|remove)\s+(all\s+)?(old|prior|previous)\s+(versions|history|handoffs|changelogs|archives?)/i;
  const zipErase = /(delete|remove|discard)\s+the\s+zip/i;
  const matchHistoryErase = normalized.match(historyErase) ?? normalized.match(zipErase);
  if (matchHistoryErase) {
    findings.push({
      ruleId: 'GEL-OUT-002_RULE_ZERO_NO_HISTORY_ERASURE',
      severity: 'DENY',
      message: 'Candidate output contradicts RULE ZERO by deleting or overwriting preserved project history.',
      evidence: matchHistoryErase[0],
    });
  }
 
  const bypassPatterns = [
    /(no\s+(policy|rule|match).{0,40}(allow|proceed|continue))/i,
    /(without\s+(an\s+)?envelope.{0,40}(allow|proceed|continue))/i,
    /(bypass|ignore|skip).{0,30}(policy|envelope|authorization|approval)/i,
  ];
  for (const pattern of bypassPatterns) {
    const matched = normalized.match(pattern);
    if (matched) {
      findings.push({
        ruleId: 'GEL-OUT-003_FAIL_CLOSED_ON_MISSING_AUTHORITY',
        severity: 'DENY',
        message: 'Candidate output instructs the system to bypass or ignore governed authorization.',
        evidence: matched[0],
      });
      break;
    }
  }
 
  const verdict = findings.some((f) => f.severity === 'DENY')
    ? 'DENY'
    : findings.length > 0
      ? 'WARN'
      : 'ALLOW';
 
  return {
    verdict,
    findings,
    checkedAt: new Date().toISOString(),
    checkedRules,
    textPreview: normalized.slice(0, 240),
    criticalDocsPresent: profile.constitutionLoaded,
  };
}
 
function normalizeWhitespace(input: string): string {
  return input.replace(/\s+/g, ' ').trim();
}
 
