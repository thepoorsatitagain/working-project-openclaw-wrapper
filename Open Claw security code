export function recordAPPDRE(
  ctx: APPDREContext,
  problem: APPProblemInput,
  patternMap: APPPatternMap | undefined,
  modifications: APPModificationSuggestion[],
  fm1Event: APPTelemetryEvent | undefined,
  slmEvents: APPTelemetryEvent[],
): APPDREAppendResult {
  const fm1StartedAt = fm1Event?.startedAt;
  const fm1CompletedAt = fm1Event?.completedAt;
  const slmStartedAt = slmEvents[0]?.startedAt;
  const slmCompletedAt = slmEvents
    .map((e) => e.completedAt)
    .filter((value): value is string => Boolean(value))
    .sort()
    .slice(-1)[0];
 
  const statusParts: string[] = [];
  statusParts.push(fm1Event?.status === 'COMPLETED' ? 'FM1_COMPLETED' : 'FM1_FAILED');
  if (slmEvents.length === 0) {
    statusParts.push('SLM_NOT_RUN');
  } else if (slmEvents.some((e) => e.status === 'COMPLETED')) {
    statusParts.push('SLM_COMPLETED');
  } else {
    statusParts.push('SLM_FAILED');
  }
 
  const slmModelCounts = new Map<string, number>();
  for (const event of slmEvents) {
    const key = event.model || 'unknown';
    slmModelCounts.set(key, (slmModelCounts.get(key) ?? 0) + 1);
  }
 
  const models: { role: 'FM1' | 'SLM'; id: string; count?: number }[] = [
    { role: 'FM1', id: fm1Event?.model ?? 'unknown' },
    ...Array.from(slmModelCounts.entries()).map(([id, count]) => ({
      role: 'SLM' as const,
      id,
      count,
    })),
  ];
 
  const record: APPDRERecord = {
    dreVersion: '1.0',
    component: 'APP_PIPELINE',
    runId: ctx.runId,
    envelopeId: ctx.envelopeId,
    who: {
      initiator: ctx.initiator,
      lane: 'APP_L1',
      models,
    },
    what: {
      operation: 'APP_PIPELINE_SUBMIT',
      status: statusParts.join('+'),
      problemHash: simpleHash(problem.problemStatement),
      patternMapSummary: patternMap
        ? {
            substrate: patternMap.substrate,
            desiredAttractor: patternMap.desiredAttractor,
          }
        : undefined,
      modificationCount: modifications.length,
    },
    when: {
      submittedAt: problem.submittedAt,
      fm1StartedAt,
      fm1CompletedAt,
      slmStartedAt,
      slmCompletedAt,
    },
    where: {
      service: ctx.service,
      host: ctx.host,
      dreStream: 'dre/app/app_runs.log',
    },
    why: {
      purpose: 'APP_EXPLORATION',
      labels: ['exploratory', 'governed', 'dre-recorded'],
    },
    how: {
      vckbDocs: ctx.vckbDocIds,
      policyRuleId: ctx.policyRuleId,
      envelopeOperations: ctx.envelopeOperations,
    },
  };
 
  return appendAPPDRERecord(record);
}
 
