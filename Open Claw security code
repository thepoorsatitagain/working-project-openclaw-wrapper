import { createHmac, createPrivateKey, createPublicKey, generateKeyPairSync, randomUUID, sign, timingSafeEqual, verify } from 'crypto';
import { DlcCapability, SignedDlc, TokenHeader } from './types';
 
function base64urlEncode(input: Buffer | string): string {
  return Buffer.from(input)
    .toString('base64')
    .replace(/=/g, '')
    .replace(/\+/g, '-')
    .replace(/\//g, '_');
}
 
function base64urlDecode(input: string): Buffer {
  const normalized = input.replace(/-/g, '+').replace(/_/g, '/');
  const padded = normalized + '='.repeat((4 - (normalized.length % 4)) % 4);
  return Buffer.from(padded, 'base64');
}
 
function hmacSign(input: string, secret: string): string {
  return base64urlEncode(createHmac('sha256', secret).update(input).digest());
}
 
function safeEqualString(a: string, b: string): boolean {
  try {
    return timingSafeEqual(Buffer.from(a), Buffer.from(b));
  } catch {
    return false;
  }
}
 
function signEd25519(input: string, privateKeyPem: string): string {
  const key = createPrivateKey(privateKeyPem);
  return base64urlEncode(sign(null, Buffer.from(input), key));
}
 
function verifyEd25519(input: string, signature: string, publicKeyPem: string): boolean {
  const key = createPublicKey(publicKeyPem);
  return verify(null, Buffer.from(input), key, base64urlDecode(signature));
}
 
function nowEpoch(): number {
  return Math.floor(Date.now() / 1000);
}
 
export interface IssueDlcOptions {
  subject: string;
  entityId: string;
  entityRole: string;
  modelId: string;
  provider: string;
  governanceProfile: string;
  allowedHosts: string[];
  allowedMethods?: string[];
  allowedOperations?: string[];
  pathPrefixes?: string[];
  liabilityPosture?: string;
  spendCeilingCents?: number;
  metadata?: Record<string, string | number | boolean>;
  ttlSeconds?: number;
  keyId?: string;
}
 
export function generateEd25519KeyPair(): { publicKeyPem: string; privateKeyPem: string } {
  const pair = generateKeyPairSync('ed25519');
  return {
    publicKeyPem: pair.publicKey.export({ type: 'spki', format: 'pem' }).toString(),
    privateKeyPem: pair.privateKey.export({ type: 'pkcs8', format: 'pem' }).toString()
  };
}
 
export function issueDlc(
  signingKey: string,
  options: IssueDlcOptions,
  algorithm: 'EdDSA' | 'HS256' = 'EdDSA'
): SignedDlc {
  const issuedAt = nowEpoch();
  const payload: DlcCapability = {
    version: 1,
    jti: randomUUID(),
    subject: options.subject,
    entityId: options.entityId,
    entityRole: options.entityRole,
    modelId: options.modelId,
    provider: options.provider,
    governanceProfile: options.governanceProfile,
    liabilityPosture: options.liabilityPosture,
    allowedHosts: normalizeList(options.allowedHosts),
    allowedMethods: normalizeList(options.allowedMethods ?? ['GET', 'POST', 'CONNECT']),
    allowedOperations: normalizeList(options.allowedOperations ?? ['http_forward', 'https_connect']),
    pathPrefixes: options.pathPrefixes?.map(normalizePathPrefix),
    spendCeilingCents: options.spendCeilingCents,
    metadata: options.metadata,
    iat: issuedAt,
    nbf: issuedAt,
    exp: issuedAt + (options.ttlSeconds ?? 300)
  };
 
  const header: TokenHeader = {
    alg: algorithm,
    typ: 'DLC',
    kid: options.keyId
  };
  const encodedHeader = base64urlEncode(JSON.stringify(header));
  const encodedPayload = base64urlEncode(JSON.stringify(payload));
  const signingInput = `${encodedHeader}.${encodedPayload}`;
  const signature = algorithm === 'EdDSA'
    ? signEd25519(signingInput, signingKey)
    : hmacSign(signingInput, signingKey);
 
  return {
    token: `${signingInput}.${signature}`,
    payload,
    header
  };
}
 
export function verifyDlc(
  token: string,
  verifier: { publicKeyPem?: string; sharedSecret?: string },
  clockSkewSeconds = 5
): DlcCapability {
  const parts = token.split('.');
  if (parts.length !== 3) {
    throw new Error('DLC format invalid');
  }
 
  const [encodedHeader, encodedPayload, signature] = parts;
  const signingInput = `${encodedHeader}.${encodedPayload}`;
  const header = JSON.parse(base64urlDecode(encodedHeader).toString('utf8')) as TokenHeader;
  if (header.typ !== 'DLC' || !header.alg) {
    throw new Error('DLC header invalid');
  }
 
  if (header.alg === 'EdDSA') {
    if (!verifier.publicKeyPem) {
      throw new Error('DLC public key not configured');
    }
    if (!verifyEd25519(signingInput, signature, verifier.publicKeyPem)) {
      throw new Error('DLC signature mismatch');
    }
  } else if (header.alg === 'HS256') {
    if (!verifier.sharedSecret) {
      throw new Error('DLC shared secret not configured');
    }
    const expected = hmacSign(signingInput, verifier.sharedSecret);
    if (!safeEqualString(signature, expected)) {
      throw new Error('DLC signature mismatch');
    }
  } else {
    throw new Error('Unsupported DLC algorithm');
  }
 
  const payload = JSON.parse(base64urlDecode(encodedPayload).toString('utf8')) as DlcCapability;
  validatePayload(payload);
 
  const now = nowEpoch();
  if (payload.nbf - clockSkewSeconds > now) {
    throw new Error('DLC not yet valid');
  }
  if (payload.exp + clockSkewSeconds < now) {
    throw new Error('DLC expired');
  }
  return payload;
}
 
function validatePayload(payload: DlcCapability): void {
  if (payload.version !== 1) throw new Error('Unsupported DLC version');
  if (!payload.subject || !payload.entityId || !payload.modelId) throw new Error('DLC required fields missing');
  if (!Array.isArray(payload.allowedHosts) || payload.allowedHosts.length === 0) throw new Error('DLC allowedHosts missing');
  if (!Array.isArray(payload.allowedMethods) || payload.allowedMethods.length === 0) throw new Error('DLC allowedMethods missing');
  if (!Array.isArray(payload.allowedOperations) || payload.allowedOperations.length === 0) throw new Error('DLC allowedOperations missing');
}
 
function normalizeList(values: string[]): string[] {
  return Array.from(new Set(values.map((value) => value.trim()).filter(Boolean)));
}
 
function normalizePathPrefix(prefix: string): string {
  if (!prefix.startsWith('/')) return `/${prefix}`;
  return prefix;
}
 
export function extractBearerToken(headerValue?: string): string | null {
  if (!headerValue) return null;
  const match = headerValue.match(/^Bearer\s+(.+)$/i);
  return match ? match[1].trim() : null;
}
 
