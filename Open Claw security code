// =============================================================================
// HYDRA KERNEL — Execution Envelope Generator + Interpreter
// Version: 0.3.0 — REAL IMPLEMENTATION
//
// Step 5: Execution Envelope Generation
// Step 6: Envelope Interpreter
//
// Constitutional Definition 4: The envelope is logically and/or
// cryptographically bound to the operation it governs and is enforced by GEL.
// No governed operation may proceed except as permitted by the active envelope.
//
// Constitutional Definition 5: The Envelope Interpreter produces allow, deny,
// or conditional outcomes for enforcement by GEL.
//
// Architectural Invariant 6: Nothing executes without an envelope.
// Architectural Invariant 8: If the envelope does not explicitly allow, DENY.
// =============================================================================
 
import { randomUUID } from 'crypto';
import {
  ExecutionEnvelope,
  EnvelopeReplayRecord,
  GELRequest,
  PolicyRule,
} from './types';
 
// -----------------------------------------------------------------------------
// Step 5: Generate Execution Envelope
// Called only when policy evaluation returns ALLOW.
// The envelope is populated from the matched policy rule — not hardcoded.
// allowedOperations comes directly from the rule that authorized the request.
// -----------------------------------------------------------------------------
export function generateEnvelope(
  req: GELRequest,
  rule: PolicyRule
): ExecutionEnvelope {
  const now      = new Date();
  const ttlMs    = rule.ttlMs ?? 30_000;
  const expiresAt = new Date(now.getTime() + ttlMs);
 
  return {
    id:                 randomUUID(),
    requestId:          req.id,
    allowedOperations:  rule.grantedOperations,   // from policy — never hardcoded
    maxTokens:          rule.maxTokens ?? 1_000,
    ttlMs,
    createdAt:          now.toISOString(),
    expiresAt:          expiresAt.toISOString(),
    policyRuleId:       rule.id,                  // audit trail
    requestPath:        req.path,                 // recorded for replay
    requestMethod:      req.method,               // recorded for replay
  };
}
 
// -----------------------------------------------------------------------------
// Step 6: Envelope Interpreter — is this operation permitted right now?
//
// Two checks, both required:
//   1. Is the operation in allowedOperations? (explicit permit)
//   2. Has the envelope expired? (TTL enforcement)
//
// Invariant 8: Both must pass. Either failure = DENY.
// Returns a structured result so the caller can log the reason.
// -----------------------------------------------------------------------------
export function interpretEnvelope(
  envelope: ExecutionEnvelope,
  requestedOperation: string
): { permitted: boolean; reason: string } {
 
  // Check 1: Expiry
  if (isEnvelopeExpired(envelope)) {
    return {
      permitted: false,
      reason: `Envelope ${envelope.id} expired at ${envelope.expiresAt} — Invariant 8: fail closed`,
    };
  }
 
  // Check 2: Operation authorization
  if (!envelope.allowedOperations.includes(requestedOperation)) {
    return {
      permitted: false,
      reason: `Operation '${requestedOperation}' not in envelope allowedOperations ` +
              `[${envelope.allowedOperations.join(', ')}] — Invariant 8: fail closed`,
    };
  }
 
  return {
    permitted: true,
    reason: `Operation '${requestedOperation}' authorized by envelope ${envelope.id} ` +
            `under policy rule ${envelope.policyRuleId}`,
  };
}
 
// -----------------------------------------------------------------------------
// Replay: reconstruct a past decision from telemetry data.
//
// Constitutional Invariant 7: Replay is required before authorization
// for high-stakes operations.
//
// Given a recorded envelope snapshot and a simulated request,
// replay the policy evaluation and compare against the original decision.
//
// This is NOT re-executing the inference. It is re-evaluating the
// governance decision to verify it was correct and consistent.
// -----------------------------------------------------------------------------
export function replayEnvelopeDecision(
  originalRequestId: string,
  originalDecision: 'ALLOW' | 'DENY',
  envelopeSnapshot: ExecutionEnvelope | null,
  replayedRequest: { path: string; method: string },
  policyRuleMatched: string,
  decisionTimestamp: string
): EnvelopeReplayRecord {
 
  const replayedAt = new Date().toISOString();
 
  // If original was DENY and no envelope exists — confirm: DENY with no envelope is correct
  if (originalDecision === 'DENY' && envelopeSnapshot === null) {
    return {
      replayId:           randomUUID(),
      originalRequestId,
      originalDecision,
      envelopeSnapshot:   null,
      policyRuleMatched,
      decisionTimestamp,
      replayedAt,
      replayVerdict:      'CONFIRMED',
      divergenceNote:     'DENY with no envelope is consistent with Invariant 8',
    };
  }
 
  // If original was ALLOW but no envelope snapshot — cannot replay
  if (originalDecision === 'ALLOW' && envelopeSnapshot === null) {
    return {
      replayId:           randomUUID(),
      originalRequestId,
      originalDecision,
      envelopeSnapshot:   null,
      policyRuleMatched,
      decisionTimestamp,
      replayedAt,
      replayVerdict:      'UNREPLAYABLE',
      divergenceNote:     'ALLOW decision recorded but envelope snapshot missing from telemetry',
    };
  }
 
  // Check: does the envelope match the request it was issued for?
  const pathMatch   = envelopeSnapshot!.requestPath   === replayedRequest.path;
  const methodMatch = envelopeSnapshot!.requestMethod === replayedRequest.method;
  const ruleMatch   = envelopeSnapshot!.policyRuleId  === policyRuleMatched;
 
  if (!pathMatch || !methodMatch || !ruleMatch) {
    return {
      replayId:           randomUUID(),
      originalRequestId,
      originalDecision,
      envelopeSnapshot,
      policyRuleMatched,
      decisionTimestamp,
      replayedAt,
      replayVerdict:      'DIVERGED',
      divergenceNote:
        `Mismatch — path: ${pathMatch}, method: ${methodMatch}, rule: ${ruleMatch}. ` +
        `Envelope recorded ${envelopeSnapshot!.requestPath} ${envelopeSnapshot!.requestMethod} ` +
        `rule ${envelopeSnapshot!.policyRuleId}`,
    };
  }
 
  return {
    replayId:           randomUUID(),
    originalRequestId,
    originalDecision,
    envelopeSnapshot,
    policyRuleMatched,
    decisionTimestamp,
    replayedAt,
    replayVerdict:      'CONFIRMED',
  };
}
 
// Utility
export function isEnvelopeExpired(envelope: ExecutionEnvelope): boolean {
  return new Date() > new Date(envelope.expiresAt);
}
 
