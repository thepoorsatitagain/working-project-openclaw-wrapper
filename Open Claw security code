      port: parseInt(process.env.EGL_PORT ?? process.env.EGL_DLC_PORT ?? '3210', 10)
    },
    dlcToken,
    dlcVerifier: dlcPublicKeyPem || process.env.EGL_DLC_SECRET ? {
      publicKeyPem: dlcPublicKeyPem,
      sharedSecret: process.env.EGL_DLC_SECRET
    } : undefined,
    gelSigner: {
      privateKeyPem: gelPrivateKeyPem,
      sharedSecret: process.env.EGL_ENVELOPE_SECRET,
      keyId: process.env.ENVELOPE_KEY_ID,
      ttlSeconds: process.env.ENVELOPE_TTL_SECONDS ? parseInt(process.env.ENVELOPE_TTL_SECONDS, 10) : 60
    },
    requestId: process.env.ENVELOPE_REQUEST_ID,
