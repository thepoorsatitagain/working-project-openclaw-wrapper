async function dispatch(): Promise<void> {
  const targetUrl = required('DISPATCH_URL');
  const dlcToken = required('HYDRA_DLC_TOKEN');
  const dlcPublicKeyPem = maybeReadFileOrValue(process.env.EGL_DLC_PUBLIC_KEY ?? process.env.EGL_DLC_PUBLIC_KEY_FILE);
  const gelPrivateKeyPem = maybeReadFileOrValue(process.env.EGL_GEL_PRIVATE_KEY ?? process.env.EGL_GEL_PRIVATE_KEY_FILE);
