// =============================================================================
// HYDRA KERNEL — Governance Plane Interceptor
// Version: 0.3.0 — REAL IMPLEMENTATION
//
// Step 2: Governance Plane Interception
// Step 3: Policy Pack Loading
// Step 4: Policy Evaluation
// Step 5: Envelope Generation
// Step 6: Envelope Interpretation
//
// Constitutional Invariant 3: Governance Plane is independent of Inference.
// This module decides. index.ts enforces. OpenClaw executes.
// Never the same component.
// =============================================================================
 
import { GELRequest, GELDecision } from './types';
import { loadPolicies, evaluatePolicies } from './policy';
import { generateEnvelope, interpretEnvelope } from './envelope';
import { logEvent } from './telemetry';
 
export function intercept(req: GELRequest): GELDecision {
 
  // ── Step 9 (partial): Log every interception. No silent degradation. ──────
  logEvent('REQUEST_INTERCEPTED', req.id, {
    method:    req.method,
    path:      req.path,
    source:    req.source,
    timestamp: req.timestamp,
  });
 
  // ── Step 3: Load Policy Pack ───────────────────────────────────────────────
  const policies = loadPolicies();
 
  // ── Step 4: Evaluate Policy Overlay ───────────────────────────────────────
  const { matched, result, grantedOperations } = evaluatePolicies(req, policies);
 
  logEvent('POLICY_EVALUATED', req.id, {
    ruleId:      matched?.id ?? 'NO_MATCH',
    ruleDesc:    matched?.description ?? 'No policy matched — default DENY',
    result,
    grantedOperations,
  });
 
  // ── DENY path ─────────────────────────────────────────────────────────────
  if (result === 'DENY') {
    const reason = matched
      ? `Policy [${matched.id}] explicitly denied: ${matched.description}`
      : 'No policy matched — Invariant 8: fail closed';
 
    logEvent('DECISION_MADE', req.id, {
      result: 'DENY',
      reason,
      envelopeId: null,
    });
 
    return {
      requestId: req.id,
      timestamp: new Date().toISOString(),
      result:    'DENY',
      reason,
    };
  }
 
  // ── Step 5: Generate Execution Envelope ───────────────────────────────────
  // Only reached if a policy explicitly ALLOW-ed the request.
  // Envelope is populated from the matched rule — allowedOperations comes
  // from policy, not hardcoded here.
  const envelope = generateEnvelope(req, matched!);
 
  // Log full envelope snapshot — this is what makes decisions replayable
  logEvent('ENVELOPE_CREATED', req.id, {
    envelope,   // full snapshot for replay reconstruction
    ruleId: matched!.id,
  });
 
  // ── Step 6: Envelope Interpreter — verify the primary operation ───────────
  // Determine the primary operation this request needs
  const primaryOperation = grantedOperations[0] ?? 'UNKNOWN';
  const interpretation   = interpretEnvelope(envelope, primaryOperation);
 
  logEvent('OPERATION_CHECKED', req.id, {
    operation:  primaryOperation,
    permitted:  interpretation.permitted,
    reason:     interpretation.reason,
    envelopeId: envelope.id,
  });
 
  // If the envelope we just created somehow doesn't permit the operation
  // (shouldn't happen, but Invariant 8 requires we check anyway)
  if (!interpretation.permitted) {
    logEvent('DECISION_MADE', req.id, {
      result:     'DENY',
      reason:     `Envelope interpreter denied: ${interpretation.reason}`,
      envelopeId: envelope.id,
    });
 
    return {
      requestId: req.id,
      timestamp: new Date().toISOString(),
      result:    'DENY',
      reason:    `Envelope interpreter denied: ${interpretation.reason}`,
    };
  }
 
  // ── ALLOW ─────────────────────────────────────────────────────────────────
  const reason = `Policy [${matched!.id}] allowed. ` +
                 `Envelope ${envelope.id} issued. ` +
                 `Operations: [${envelope.allowedOperations.join(', ')}]`;
 
  logEvent('DECISION_MADE', req.id, {
    result:     'ALLOW',
    reason,
    envelopeId: envelope.id,
  });
 
  return {
    requestId: req.id,
    timestamp: new Date().toISOString(),
    result:    'ALLOW',
    reason,
    envelope,
  };
}
 
