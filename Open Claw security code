    }
 
    const problem: APPProblemInput = {
      id: requestId,
      submittedAt: new Date().toISOString(),
      problemStatement,
      domain: typeof domain === 'string' ? domain : undefined,
    };
 
    const vckbDocsInLane = Array.from(new Set([...APP_FM1_DOC_IDS, ...APP_SLM_DOC_IDS, 'CONSTITUTION']));
 
    logEvent('FORWARDED', requestId, {
      destination:    'APP_PIPELINE_LANE_L1',
      path:           req.path,
      envelopeId:     envelope.id,
      operations:     envelope.allowedOperations,
      domain:         domain ?? 'unspecified',
      problemLength:  problemStatement.length,
      vckbDocsInLane,
      replay:         `/gel/replay/${requestId}`,
    });
 
    const allowFallback = process.env.APP_ALLOW_FM1_FALLBACK === '1';
    const modelTimeoutMs = parseInt(process.env.APP_MODEL_TIMEOUT_MS ?? '20000', 10);
 
    try {
      const { patternMap, telemetry: fm1Telemetry } = await runPatternMapper(
        problem,
        vckbResult.documents,
        undefined,
        { allowFallback, timeoutMs: modelTimeoutMs },
      );
 
      logEvent('FORWARDED', requestId, {
        destination: 'APP_PIPELINE_FM1_COMPLETE',
        model: fm1Telemetry.model,
        status: fm1Telemetry.status,
        notes: fm1Telemetry.notes,
      });
 
      let modifications: APPModificationSuggestion[] = [];
      let slmTelemetry: APPTelemetryEvent[] = [];
 
      if (patternMap.substrate !== '[FM1_FAILED]') {
        const slmResult = await runModificationSuggesters(
          patternMap,
          vckbResult.documents,
          parseInt(process.env.APP_SLM_COUNT ?? '3', 10),
          undefined,
          { timeoutMs: modelTimeoutMs },
        );
        modifications = slmResult.modifications;
        slmTelemetry = slmResult.telemetry;
      }
 
      const dreResult = recordAPPDRE(
        {
          runId: requestId,
          envelopeId: envelope.id,
          initiator: 'human:unknown',
          service: 'hydra-gel',
          host: req.hostname,
          policyRuleId: envelope.policyRuleId,
          envelopeOperations: envelope.allowedOperations,
          vckbDocIds: vckbDocsInLane,
        },
        problem,
        patternMap,
        modifications,
        fm1Telemetry,
        slmTelemetry,
      );
 
      if (!dreResult.ok) {
        logEvent('FORWARDED', requestId, {
          destination: 'APP_PIPELINE_DRE_WARNING',
          error: dreResult.error,
        });
      }
 
      res.json({
        status: modifications.length > 0 ? 'MODIFICATIONS_GENERATED' : 'PATTERN_MAPPED',
        governed: true,
        envelopeId: envelope.id,
        replayable: true,
        replay: `/gel/replay/${requestId}`,
        vckbDocsInLane,
        problemId: problem.id,
        patternMap,
        modifications,
        telemetry: [fm1Telemetry, ...slmTelemetry],
        dreRecorded: dreResult.ok,
        note: modifications.length > 0
          ? 'FM1 and minimal parallel SLM generation completed.'
          : 'FM1 completed. No SLM modifications were returned.',
