import * as fs from 'fs';
import * as http from 'http';
import * as net from 'net';
import * as path from 'path';
import { randomUUID } from 'crypto';
import { extractBearerToken, verifyDlc } from './capability';
import { decodeEnvelopeToken, verifyEnvelope } from './envelope';
import { decideEgress } from './policy';
import { Telemetry } from './telemetry';
import { EnforcementInput, ServerConfig } from './types';
 
function readInlineOrFile(value?: string): string | undefined {
  if (!value) return undefined;
  if (value.includes('BEGIN')) return value;
  if (fs.existsSync(value)) return fs.readFileSync(value, 'utf8');
  return value;
}
 
export function getConfig(): ServerConfig {
  return {
    port: parseInt(process.env.EGL_DLC_PORT ?? '3210', 10),
    adminToken: process.env.EGL_DLC_ADMIN_TOKEN ?? 'hydra-local-dev',
    dlcPublicKey: readInlineOrFile(process.env.EGL_DLC_PUBLIC_KEY ?? process.env.EGL_DLC_PUBLIC_KEY_FILE),
    dlcSecret: process.env.EGL_DLC_SECRET,
    envelopePublicKey: readInlineOrFile(process.env.EGL_GEL_PUBLIC_KEY ?? process.env.EGL_GEL_PUBLIC_KEY_FILE),
    envelopeSecret: process.env.EGL_ENVELOPE_SECRET,
    telemetryPath: process.env.EGL_DLC_TELEMETRY_PATH ?? path.join(process.env.HOME ?? '~', '.hydra', 'egl-dlc-telemetry.jsonl'),
    defaultAllowedHosts: (process.env.EGL_DEFAULT_ALLOWED_HOSTS ?? 'localhost,127.0.0.1').split(',').map((v) => v.trim()).filter(Boolean)
  };
}
 
function replyJson(res: any, statusCode: number, body: unknown): void {
  res.writeHead(statusCode, { 'Content-Type': 'application/json' });
  res.end(JSON.stringify(body));
}
 
export function createEglServer(overrides: Partial<ServerConfig> = {}) {
  const config: ServerConfig = { ...getConfig(), ...overrides };
  const telemetry = new Telemetry(config.telemetryPath);
 
  function authorize(requestId: string, input: EnforcementInput, headers: any) {
    const token = headers['x-hydra-dlc'] as string | undefined
      ?? extractBearerToken(headers['proxy-authorization'] as string | undefined)
      ?? extractBearerToken(headers.authorization as string | undefined)
      ?? null;
 
    telemetry.write({
      timestamp: new Date().toISOString(),
      requestId,
      phase: 'REQUEST',
      destinationHost: input.destinationHost,
      destinationPort: input.destinationPort,
      method: input.method,
      operation: input.operation,
      detail: {
        path: input.path,
        input: {
          destinationHost: input.destinationHost,
          destinationPort: input.destinationPort,
          method: input.method,
          operation: input.operation,
          path: input.path
        }
      }
    });
 
    if (!token) {
      return { ok: false, status: 401, ruleId: 'DLC-AUTH-001', reason: 'DLC token missing' };
    }
 
    try {
      const dlc = verifyDlc(token, {
        publicKeyPem: config.dlcPublicKey,
        sharedSecret: config.dlcSecret
      });
      const envelope = decodeEnvelopeToken((headers['x-hydra-envelope'] as string | undefined) ?? undefined);
      const envelopeDecision = verifyEnvelope(envelope, input, {
        publicKeyPem: config.envelopePublicKey,
        sharedSecret: config.envelopeSecret
      }, dlc);
      if (!envelopeDecision.ok) {
        return { ok: false, status: 403, ruleId: 'ENV-001', reason: envelopeDecision.reason, dlc, envelope: envelopeDecision.payload };
      }
 
      const decision = decideEgress(input, dlc, config.defaultAllowedHosts);
      if (decision.effect === 'DENY') {
        return { ok: false, status: 403, ruleId: decision.ruleId, reason: decision.reason, dlc, envelope: envelopeDecision.payload };
      }
 
      return { ok: true, status: 200, ruleId: decision.ruleId, reason: decision.reason, dlc, envelope: envelopeDecision.payload };
    } catch (error) {
      return {
        ok: false,
        status: 401,
        ruleId: 'DLC-AUTH-002',
        reason: error instanceof Error ? error.message : 'DLC validation failed'
      };
    }
  }
 
  function stripInternalHeaders(headers: any): any {
    const copy: any = { ...headers };
    delete copy['x-hydra-dlc'];
    delete copy['x-hydra-envelope'];
    delete copy['proxy-authorization'];
    return copy;
  }
 
  const server = http.createServer((req, res) => {
    if (req.url === '/egl-dlc/health') {
      replyJson(res, 200, {
        status: 'OK',
        component: 'Standalone EGL + DLC',
        version: '0.4.0',
        envelopeRequired: Boolean(config.envelopePublicKey || config.envelopeSecret),
        dlcVerification: config.dlcPublicKey ? 'Ed25519' : (config.dlcSecret ? 'HS256' : 'UNCONFIGURED'),
        defaultAllowedHosts: config.defaultAllowedHosts,
        port: config.port
      });
      return;
    }
 
    if (req.url === '/egl-dlc/telemetry') {
      const auth = (req.headers.authorization ?? '').toString();
      if (!auth.includes(config.adminToken)) {
        replyJson(res, 403, { error: 'ADMIN_TOKEN_REQUIRED' });
        return;
      }
      replyJson(res, 200, telemetry.readAll());
      return;
    }
 
    const requestId = randomUUID();
    let url: URL;
    try {
      url = new URL(req.url ?? '', `http://${req.headers.host ?? 'invalid.local'}`);
    } catch {
      replyJson(res, 400, { error: 'BAD_URL', requestId });
      return;
    }
 
    const input: EnforcementInput = {
      destinationHost: url.hostname,
      destinationPort: url.port ? parseInt(url.port, 10) : 80,
      method: (req.method ?? 'GET').toUpperCase(),
      operation: 'http_forward',
      path: `${url.pathname}${url.search}`
    };
 
    const authz = authorize(requestId, input, req.headers);
    telemetry.write({
      timestamp: new Date().toISOString(),
      requestId,
      phase: 'DECISION',
      destinationHost: input.destinationHost,
      destinationPort: input.destinationPort,
      method: input.method,
      operation: input.operation,
      outcome: authz.ok ? 'ALLOW' : 'DENY',
      ruleId: authz.ruleId,
      reason: authz.reason,
      dlcJti: authz.dlc?.jti,
      subject: authz.dlc?.subject,
      entityId: authz.dlc?.entityId,
      detail: {
        path: input.path,
        envelopeRequestId: authz.envelope?.requestId,
        envelopeClaim: authz.envelope,
        dlcScope: authz.dlc
      }
    });
 
    if (!authz.ok) {
      replyJson(res, authz.status, {
        error: 'EGL_DLC_DENIED',
        requestId,
        ruleId: authz.ruleId,
        reason: authz.reason
      });
      return;
    }
 
    const upstream = http.request({
      hostname: url.hostname,
      port: input.destinationPort,
      path: `${url.pathname}${url.search}`,
      method: req.method,
      headers: stripInternalHeaders(req.headers)
    }, (upstreamRes) => {
      res.writeHead(upstreamRes.statusCode ?? 200, upstreamRes.headers);
      upstreamRes.pipe(res);
      telemetry.write({
        timestamp: new Date().toISOString(),
        requestId,
        phase: 'FORWARD',
        destinationHost: input.destinationHost,
        destinationPort: input.destinationPort,
        method: input.method,
        operation: input.operation,
        outcome: 'ALLOW',
        ruleId: authz.ruleId,
        statusCode: upstreamRes.statusCode,
        detail: {
          path: input.path,
          envelopeRequestId: authz.envelope?.requestId
        }
      });
    });
 
    upstream.on('error', (error) => {
      telemetry.write({
        timestamp: new Date().toISOString(),
        requestId,
        phase: 'ERROR',
        destinationHost: input.destinationHost,
        destinationPort: input.destinationPort,
        method: input.method,
        operation: input.operation,
        reason: error.message,
        detail: { path: input.path }
      });
      replyJson(res, 502, { error: 'UPSTREAM_ERROR', requestId, message: error.message });
    });
 
    req.pipe(upstream);
  });
 
  server.on('connect', (req, clientSocket, head) => {
    const requestId = randomUUID();
    const [destinationHost, portRaw] = (req.url ?? '').split(':');
    const destinationPort = parseInt(portRaw ?? '443', 10);
    const input: EnforcementInput = {
      destinationHost,
      destinationPort,
      method: 'CONNECT',
      operation: 'https_connect'
    };
 
    const authz = authorize(requestId, input, req.headers);
    telemetry.write({
      timestamp: new Date().toISOString(),
      requestId,
      phase: 'DECISION',
      destinationHost,
      destinationPort,
      method: 'CONNECT',
      operation: 'https_connect',
      outcome: authz.ok ? 'ALLOW' : 'DENY',
      ruleId: authz.ruleId,
      reason: authz.reason,
      dlcJti: authz.dlc?.jti,
      subject: authz.dlc?.subject,
      entityId: authz.dlc?.entityId,
      detail: {
        envelopeRequestId: authz.envelope?.requestId,
        envelopeClaim: authz.envelope,
        dlcScope: authz.dlc
      }
    });
 
    if (!authz.ok) {
      clientSocket.write('HTTP/1.1 403 Forbidden\r\n\r\n');
      clientSocket.destroy();
      return;
    }
 
    const upstream = net.connect(destinationPort, destinationHost, () => {
      clientSocket.write('HTTP/1.1 200 Connection Established\r\n\r\n');
      if (head.length > 0) upstream.write(head);
      upstream.pipe(clientSocket);
      clientSocket.pipe(upstream);
      telemetry.write({
        timestamp: new Date().toISOString(),
        requestId,
        phase: 'FORWARD',
        destinationHost,
        destinationPort,
        method: 'CONNECT',
        operation: 'https_connect',
        outcome: 'ALLOW',
        ruleId: authz.ruleId,
        detail: { envelopeRequestId: authz.envelope?.requestId }
      });
    });
 
    upstream.on('error', (error) => {
      telemetry.write({
        timestamp: new Date().toISOString(),
        requestId,
        phase: 'ERROR',
        destinationHost,
        destinationPort,
        method: 'CONNECT',
        operation: 'https_connect',
        reason: error.message
      });
      clientSocket.write('HTTP/1.1 502 Bad Gateway\r\n\r\n');
      clientSocket.destroy();
    });
 
    clientSocket.on('error', () => upstream.destroy());
  });
 
  return { server, config, telemetry };
}
 
function logStartup(config: ServerConfig): void {
  console.log('\n╔══════════════════════════════════════════════╗');
  console.log('║  Standalone Exit Portal + DLC — v0.4.0      ║');
  console.log('╚══════════════════════════════════════════════╝');
  console.log(`Port               : ${config.port}`);
  console.log(`Telemetry          : ${config.telemetryPath}`);
  console.log(`Envelope required  : ${Boolean(config.envelopePublicKey || config.envelopeSecret)}`);
  console.log(`DLC verification   : ${config.dlcPublicKey ? 'Ed25519' : (config.dlcSecret ? 'HS256' : 'UNCONFIGURED')}`);
  console.log(`Default hosts      : ${config.defaultAllowedHosts.join(', ')}`);
  if (!config.dlcPublicKey && config.dlcSecret === 'hydra-dev-dlc-secret') {
    console.log('WARNING            : using default DLC secret');
  }
  console.log('');
}
 
if (require.main === module) {
  const { server, config } = createEglServer();
  server.listen(config.port, () => logStartup(config));
}
 
