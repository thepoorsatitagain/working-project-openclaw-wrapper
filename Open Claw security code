import { createHmac, createPrivateKey, createPublicKey, randomUUID, sign, timingSafeEqual, verify } from 'crypto';
import { DlcCapability, EnvelopeClaim, EnforcementInput, SignedEnvelope } from './types';
 
function base64urlEncode(input: Buffer | string): string {
  return Buffer.from(input)
    .toString('base64')
    .replace(/=/g, '')
    .replace(/\+/g, '-')
    .replace(/\//g, '_');
}
 
function base64urlDecode(input: string): Buffer {
  const normalized = input.replace(/-/g, '+').replace(/_/g, '/');
  const padded = normalized + '='.repeat((4 - (normalized.length % 4)) % 4);
  return Buffer.from(padded, 'base64');
}
 
function canonicalize(claim: EnvelopeClaim): string {
  return [
    claim.requestId,
    claim.operation,
    claim.destinationHost,
    String(claim.destinationPort),
    claim.method.toUpperCase(),
    claim.path ?? '',
    claim.dlcJti ?? '',
    claim.entityId ?? '',
    claim.subject ?? '',
    claim.createdAt,
    claim.expiresAt
  ].join('|');
}
 
function hmac(input: string, secret: string): string {
  return base64urlEncode(createHmac('sha256', secret).update(input).digest());
}
 
function signEd25519(input: string, privateKeyPem: string): string {
  const key = createPrivateKey(privateKeyPem);
  return base64urlEncode(sign(null, Buffer.from(input), key));
}
 
function verifyEd25519(input: string, signature: string, publicKeyPem: string): boolean {
  const key = createPublicKey(publicKeyPem);
  return verify(null, Buffer.from(input), key, base64urlDecode(signature));
}
 
function safeEqualString(a: string, b: string): boolean {
  try {
    return timingSafeEqual(Buffer.from(a), Buffer.from(b));
  } catch {
    return false;
  }
}
 
export function mintEnvelope(
  signingKey: string,
  input: EnforcementInput,
  dlc?: DlcCapability,
  options?: { ttlSeconds?: number; keyId?: string; requestId?: string },
  algorithm: 'EdDSA' | 'HS256' = 'EdDSA'
): SignedEnvelope {
  const createdAt = new Date();
  const expiresAt = new Date(createdAt.getTime() + 1000 * (options?.ttlSeconds ?? 60));
  const payload: EnvelopeClaim = {
    requestId: options?.requestId ?? randomUUID(),
    operation: input.operation,
    destinationHost: input.destinationHost,
    destinationPort: input.destinationPort,
    method: input.method.toUpperCase(),
    path: input.path,
    dlcJti: dlc?.jti,
    entityId: dlc?.entityId,
    subject: dlc?.subject,
    createdAt: createdAt.toISOString(),
    expiresAt: expiresAt.toISOString()
  };
 
  const header = {
    alg: algorithm,
    typ: 'HYDRA_ENVELOPE' as const,
    kid: options?.keyId
  };
  const encodedHeader = base64urlEncode(JSON.stringify(header));
  const encodedPayload = base64urlEncode(JSON.stringify(payload));
  const signingInput = `${encodedHeader}.${encodedPayload}`;
  const signature = algorithm === 'EdDSA'
    ? signEd25519(signingInput, signingKey)
    : hmac(signingInput, signingKey);
 
  return {
    token: `${signingInput}.${signature}`,
    payload,
    header
  };
}
 
export function decodeEnvelopeToken(raw: string | undefined): SignedEnvelope | undefined {
  if (!raw) return undefined;
  const parts = raw.split('.');
  if (parts.length !== 3) return undefined;
  try {
    const header = JSON.parse(base64urlDecode(parts[0]).toString('utf8')) as SignedEnvelope['header'];
    const payload = JSON.parse(base64urlDecode(parts[1]).toString('utf8')) as EnvelopeClaim;
    return { token: raw, header, payload };
  } catch {
    return undefined;
  }
}
 
export function verifyEnvelope(
  envelope: SignedEnvelope | undefined,
  input: EnforcementInput,
  verifier?: { publicKeyPem?: string; sharedSecret?: string },
  expectedDlc?: DlcCapability
): { ok: boolean; reason: string; payload?: EnvelopeClaim } {
  if (!verifier?.publicKeyPem && !verifier?.sharedSecret) {
    return { ok: true, reason: 'Envelope verification disabled' };
  }
  if (!envelope) {
    return { ok: false, reason: 'Envelope missing' };
  }
  if (envelope.header.typ !== 'HYDRA_ENVELOPE') {
    return { ok: false, reason: 'Envelope header invalid' };
  }
 
  const signingInput = envelope.token.split('.').slice(0, 2).join('.');
  const signature = envelope.token.split('.')[2];
  if (envelope.header.alg === 'EdDSA') {
    if (!verifier.publicKeyPem) return { ok: false, reason: 'Envelope public key not configured' };
    if (!verifyEd25519(signingInput, signature, verifier.publicKeyPem)) {
      return { ok: false, reason: 'Envelope signature invalid' };
    }
  } else if (envelope.header.alg === 'HS256') {
    if (!verifier.sharedSecret) return { ok: false, reason: 'Envelope shared secret not configured' };
    const expected = hmac(signingInput, verifier.sharedSecret);
    if (!safeEqualString(signature, expected)) {
      return { ok: false, reason: 'Envelope signature invalid' };
    }
  } else {
    return { ok: false, reason: 'Envelope algorithm unsupported' };
  }
 
  const payload = envelope.payload;
  if (new Date(payload.expiresAt).getTime() < Date.now()) {
    return { ok: false, reason: 'Envelope expired' };
  }
 
  if (
    payload.destinationHost !== input.destinationHost ||
    payload.destinationPort !== input.destinationPort ||
    payload.method.toUpperCase() !== input.method.toUpperCase() ||
    payload.operation !== input.operation ||
    (payload.path ?? '') !== (input.path ?? '')
  ) {
    return { ok: false, reason: 'Envelope does not match outbound request' };
  }
 
  if (expectedDlc) {
    if (payload.dlcJti && payload.dlcJti !== expectedDlc.jti) {
      return { ok: false, reason: 'Envelope DLC binding mismatch' };
    }
    if (payload.entityId && payload.entityId !== expectedDlc.entityId) {
      return { ok: false, reason: 'Envelope entity binding mismatch' };
    }
    if (payload.subject && payload.subject !== expectedDlc.subject) {
      return { ok: false, reason: 'Envelope subject binding mismatch' };
    }
  }
 
  return { ok: true, reason: 'Envelope valid', payload };
}
 
