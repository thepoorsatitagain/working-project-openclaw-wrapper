#!/bin/bash
# =============================================================================
# gel-check.sh — Pre-authorization check against Hydra GEL
# Called by the hydra-gel OpenClaw skill before any consequential action
#
# Exit codes:
#   0 = ALLOW  (envelope ID printed to stdout)
#   1 = DENY   (reason printed to stdout)
#   2 = GEL_UNAVAILABLE (GEL not running or unreachable)
#
# Usage:
#   ./gel-check.sh --skill <name> --operation <op> --target <target> --summary <text>
# =============================================================================
 
set -euo pipefail
 
GEL_URL="${GEL_URL:-http://localhost:3100}"
GEL_ADMIN_TOKEN="${GEL_ADMIN_TOKEN:-hydra-local-dev}"
 
# --- Parse args ---
SKILL_NAME=""
OPERATION=""
TARGET=""
SUMMARY=""
 
while [[ $# -gt 0 ]]; do
  case $1 in
    --skill)    SKILL_NAME="$2";  shift 2 ;;
    --operation) OPERATION="$2"; shift 2 ;;
    --target)   TARGET="$2";     shift 2 ;;
    --summary)  SUMMARY="$2";    shift 2 ;;
    *) echo "Unknown argument: $1" >&2; exit 2 ;;
  esac
done
 
if [[ -z "$SKILL_NAME" || -z "$OPERATION" ]]; then
  echo "ERROR: --skill and --operation are required" >&2
  exit 2
fi
 
# --- Check GEL is reachable ---
if ! curl -sf --max-time 3 "$GEL_URL/gel/health" > /dev/null 2>&1; then
  echo "GEL_UNAVAILABLE: Cannot reach GEL at $GEL_URL"
  echo "Start the Hydra GEL server before executing consequential actions."
  exit 2
fi
 
# --- Build request payload ---
PAYLOAD=$(cat <<EOF
{
  "skillName": "$SKILL_NAME",
  "operation": "$OPERATION",
  "target": "$TARGET",
  "payloadSummary": "$SUMMARY",
  "requestedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "source": "openclaw-skill"
}
EOF
)
 
# --- Call GEL skill-check endpoint ---
RESPONSE=$(curl -sf \
  --max-time 10 \
  -X POST "$GEL_URL/gel/skill-check" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $GEL_ADMIN_TOKEN" \
  -d "$PAYLOAD" \
  2>/dev/null) || {
  echo "GEL_UNAVAILABLE: GEL responded but skill-check endpoint failed"
  exit 2
}
 
# --- Parse response ---
DECISION=$(echo "$RESPONSE" | node -e "
  let d=''; process.stdin.on('data',c=>d+=c);
  process.stdin.on('end',()=>{
    try { const r=JSON.parse(d); console.log(r.decision||'DENY'); }
    catch(e) { console.log('DENY'); }
  });
" 2>/dev/null || echo "DENY")
 
ENVELOPE_ID=$(echo "$RESPONSE" | node -e "
  let d=''; process.stdin.on('data',c=>d+=c);
  process.stdin.on('end',()=>{
    try { const r=JSON.parse(d); console.log(r.envelopeId||''); }
    catch(e) { console.log(''); }
  });
" 2>/dev/null || echo "")
 
REQUEST_ID=$(echo "$RESPONSE" | node -e "
  let d=''; process.stdin.on('data',c=>d+=c);
  process.stdin.on('end',()=>{
    try { const r=JSON.parse(d); console.log(r.requestId||''); }
    catch(e) { console.log(''); }
  });
" 2>/dev/null || echo "")
 
REASON=$(echo "$RESPONSE" | node -e "
  let d=''; process.stdin.on('data',c=>d+=c);
  process.stdin.on('end',()=>{
    try { const r=JSON.parse(d); console.log(r.reason||'No reason provided'); }
    catch(e) { console.log('Parse error'); }
  });
" 2>/dev/null || echo "Unknown")
 
# --- Return result ---
if [[ "$DECISION" == "ALLOW" ]]; then
  echo "ALLOW"
  echo "envelope_id=$ENVELOPE_ID"
  echo "request_id=$REQUEST_ID"
  echo "replay=$GEL_URL/gel/replay/$REQUEST_ID"
  exit 0
else
  echo "DENY"
  echo "reason=$REASON"
  echo "request_id=$REQUEST_ID"
  echo "replay=$GEL_URL/gel/replay/$REQUEST_ID"
  exit 1
fi
 
