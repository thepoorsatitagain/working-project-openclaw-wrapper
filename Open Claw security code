  const publicKeyPem = maybeReadFileOrValue(process.env.EGL_DLC_PUBLIC_KEY ?? process.env.EGL_DLC_PUBLIC_KEY_FILE);
  const sharedSecret = process.env.EGL_DLC_SECRET;
