  fs.writeFileSync(`${prefix}.private.pem`, pair.privateKeyPem, 'utf8');
  fs.writeFileSync(`${prefix}.public.pem`, pair.publicKeyPem, 'utf8');
  console.log(JSON.stringify({
    privateKeyPath: `${prefix}.private.pem`,
    publicKeyPath: `${prefix}.public.pem`
  }, null, 2));
}
 
function issue(): void {
  const privateKeyPem = maybeReadFileOrValue(process.env.EGL_DLC_PRIVATE_KEY ?? process.env.EGL_DLC_PRIVATE_KEY_FILE);
  const sharedSecret = process.env.EGL_DLC_SECRET;
  const algorithm = privateKeyPem ? 'EdDSA' : 'HS256';
  const signingKey = privateKeyPem ?? required('EGL_DLC_SECRET', 'hydra-dev-dlc-secret');
 
  const signed = issueDlc(signingKey, {
    subject: required('DLC_SUBJECT', 'local-agent'),
    entityId: required('DLC_ENTITY_ID', 'hydra-lab'),
    entityRole: required('DLC_ENTITY_ROLE', 'operator'),
    modelId: required('DLC_MODEL_ID', 'claude-or-openclaw'),
    provider: required('DLC_PROVIDER', 'local'),
    governanceProfile: required('DLC_GOVERNANCE_PROFILE', 'default-governed-egress'),
    allowedHosts: required('DLC_ALLOWED_HOSTS', 'api.openai.com,api.anthropic.com').split(','),
    allowedMethods: required('DLC_ALLOWED_METHODS', 'POST,CONNECT').split(','),
    allowedOperations: required('DLC_ALLOWED_OPERATIONS', 'http_forward,https_connect').split(','),
    pathPrefixes: (process.env.DLC_PATH_PREFIXES ?? '').split(',').map((v) => v.trim()).filter(Boolean),
    liabilityPosture: process.env.DLC_LIABILITY_POSTURE,
    spendCeilingCents: process.env.DLC_SPEND_CEILING_CENTS ? parseInt(process.env.DLC_SPEND_CEILING_CENTS, 10) : undefined,
    ttlSeconds: process.env.DLC_TTL_SECONDS ? parseInt(process.env.DLC_TTL_SECONDS, 10) : 300,
    keyId: process.env.DLC_KEY_ID
  }, algorithm);
 
  console.log(JSON.stringify({
    algorithm,
    verifierHint: privateKeyPem ? 'configure EGL_DLC_PUBLIC_KEY or EGL_DLC_PUBLIC_KEY_FILE' : 'configure EGL_DLC_SECRET',
