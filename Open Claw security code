}
 
const command = process.argv[2];
 
(async () => {
  try {
    if (command === 'genkeys') {
      genkeys(process.argv[3]);
    } else if (command === 'issue') {
      issue();
    } else if (command === 'inspect') {
      inspect(process.argv[3]);
    } else if (command === 'mint-envelope') {
      mintEnvelopeCli();
    } else if (command === 'inspect-envelope') {
