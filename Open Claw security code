export function appendAPPDRERecord(record: APPDRERecord): APPDREAppendResult {
  const dreDir = path.resolve(process.cwd(), 'dre', 'app');
  const dreFile = path.join(dreDir, 'app_runs.log');
 
  try {
    if (!fs.existsSync(dreDir)) {
      fs.mkdirSync(dreDir, { recursive: true });
    }
 
    fs.appendFileSync(dreFile, JSON.stringify(record) + '\n', { encoding: 'utf8' });
    return { ok: true };
  } catch (err) {
    return {
      ok: false,
      error: err instanceof Error ? err.message : String(err),
    };
  }
}
 
function simpleHash(input: string): string {
  let hash = 0;
  for (let i = 0; i < input.length; i++) {
    const chr = input.charCodeAt(i);
    hash = (hash << 5) - hash + chr;
    hash |= 0;
  }
  return `h${(hash >>> 0).toString(16)}`;
}
 
function normalizeEpistemicOrigin(value: unknown): APPEpistemicOrigin | undefined {
  if (typeof value !== 'string') return undefined;
  const normalized = value.trim().toUpperCase().replace(/[^A-Z]+/g, '_');
  if (
    normalized === 'STRONG_PATTERN_EXTRAPOLATION' ||
    normalized === 'WEAK_PATTERN_EXTENSION' ||
    normalized === 'PURE_CREATIVE_LEAP' ||
    normalized === 'UNSPECIFIED'
  ) {
    return normalized;
  }
  return undefined;
}
 
function normalizeRiskClass(value: unknown): APPRiskClass | undefined {
  if (typeof value !== 'string') return undefined;
  const normalized = value.trim().toUpperCase();
  if (normalized === 'LOW' || normalized === 'MEDIUM' || normalized === 'HIGH' || normalized === 'UNKNOWN') {
    return normalized;
  }
  return undefined;
}
 
function buildSuggestionId(modelId: string, ordinal: number, modification: string): string {
  return `SLM-${simpleHash(`${modelId}:${ordinal}:${modification}`)}`;
}
 
function extractLikelyJSON(raw: string): string {
  const trimmed = raw.trim();
  if (!trimmed) return trimmed;
 
  if (trimmed.startsWith('```')) {
    const withoutFenceStart = trimmed.replace(/^```(?:json)?\s*/i, '');
    const fenceEnd = withoutFenceStart.lastIndexOf('```');
    if (fenceEnd >= 0) {
      return withoutFenceStart.slice(0, fenceEnd).trim();
    }
  }
 
  const firstBrace = trimmed.indexOf('{');
  const firstBracket = trimmed.indexOf('[');
  const starts = [firstBrace, firstBracket].filter((n) => n >= 0);
  const lastBrace = trimmed.lastIndexOf('}');
  const lastBracket = trimmed.lastIndexOf(']');
  const ends = [lastBrace, lastBracket].filter((n) => n >= 0);
 
  if (starts.length > 0 && ends.length > 0) {
    const start = Math.min(...starts);
    const end = Math.max(...ends);
    if (end > start) {
      return trimmed.slice(start, end + 1);
    }
  }
 
  return trimmed;
}
 
function safeParseJSON(raw: string, label: string): unknown {
  const candidate = extractLikelyJSON(raw);
  try {
    return JSON.parse(candidate);
  } catch (err) {
    throw new Error(
      `${label} returned non-JSON payload: ${err instanceof Error ? err.message : String(err)}`,
    );
  }
}
 
function validatePatternMap(value: unknown): APPPatternMap {
  const v = value as Record<string, unknown> | null | undefined;
  const errors: string[] = [];
 
  const substrate = typeof v?.substrate === 'string' ? v.substrate.trim() : '';
  const desiredAttractor =
    typeof v?.desiredAttractor === 'string' ? v.desiredAttractor.trim() : '';
  const recurringPatterns = Array.isArray(v?.recurringPatterns)
    ? v.recurringPatterns.map((p) => String(p))
    : [];
  const stabilityMechanisms = Array.isArray(v?.stabilityMechanisms)
    ? v.stabilityMechanisms.map((p) => String(p))
    : [];
  const analysisNotes =
    typeof v?.analysisNotes === 'string' ? v.analysisNotes : '[no analysisNotes provided]';
 
  if (!substrate) errors.push('substrate missing');
  if (!desiredAttractor) errors.push('desiredAttractor missing');
 
  if (errors.length > 0) {
    throw new Error(`Invalid APPPatternMap from FM1: ${errors.join(', ')}`);
  }
 
  return {
    substrate,
    recurringPatterns,
    stabilityMechanisms,
    desiredAttractor,
    analysisNotes,
  };
}
 
function validateModificationSuggestion(
  value: unknown,
  modelId: string,
  ordinal: number,
): APPModificationSuggestion {
  const v = value as Record<string, unknown> | null | undefined;
  const modification = typeof v?.modification === 'string' ? v.modification.trim() : '';
  const rationale = typeof v?.rationale === 'string' ? v.rationale.trim() : '';
 
  if (!modification) {
    throw new Error('APPModificationSuggestion missing "modification"');
  }
 
  return {
    id:
      typeof v?.id === 'string' && v.id.trim()
        ? v.id.trim()
        : buildSuggestionId(modelId, ordinal, modification),
    suggestedBy:
      typeof v?.suggestedBy === 'string' && v.suggestedBy.trim()
        ? v.suggestedBy.trim()
        : modelId,
    modification,
    rationale: rationale || '[no rationale provided]',
    epistemicOrigin: normalizeEpistemicOrigin(v?.epistemicOrigin),
    riskClass: normalizeRiskClass(v?.riskClass),
  };
}
 
export async function runPatternMapper(
  problem: APPProblemInput,
  vckbDocuments: VCKBDocument[],
  client: ModelClient = defaultModelClient,
  opts?: { allowFallback?: boolean; timeoutMs?: number },
): Promise<{ patternMap: APPPatternMap; telemetry: APPTelemetryEvent }> {
  const telemetry: APPTelemetryEvent = {
    step: 'A_PATTERN_MAPPER',
    model: 'FM1_APP_L1',
    startedAt: new Date().toISOString(),
    status: 'STARTED',
  };
 
  try {
    const vckbContext = buildVCKBContext(vckbDocuments, [...APP_FM1_DOC_IDS]);
 
    const modelResponse = await client.run(
      {
        lane: 'APP_L1',
        capability: 'FM1_PATTERN_MAPPER',
        problemStatement: problem.problemStatement,
        vckbContext,
        modelHint: 'frontier_fm1',
      },
      opts?.timeoutMs,
    );
 
    telemetry.tokensUsed = modelResponse.tokensUsed;
    telemetry.model = modelResponse.modelId;
 
    const parsed = safeParseJSON(modelResponse.rawText, 'FM1_PATTERN_MAPPER');
    const patternMap = validatePatternMap(parsed);
 
    telemetry.completedAt = new Date().toISOString();
    telemetry.status = 'COMPLETED';
    telemetry.notes = `FM1 pattern mapping completed using ${APP_FM1_DOC_IDS.join(', ')}`;
 
    return { patternMap, telemetry };
  } catch (err) {
    telemetry.completedAt = new Date().toISOString();
    telemetry.status = 'FAILED';
    telemetry.notes = `FM1 error: ${err instanceof Error ? err.message : String(err)}`;
 
    if (opts?.allowFallback) {
      const fallback: APPPatternMap = {
        substrate: '[FM1_FAILED]',
        recurringPatterns: [],
        stabilityMechanisms: [],
        desiredAttractor: '[UNKNOWN]',
        analysisNotes: `FM1 failed: ${telemetry.notes}; problem: "${problem.problemStatement}"`,
      };
      return { patternMap: fallback, telemetry };
    }
 
    throw Object.assign(new Error(`FM1 failed: ${telemetry.notes}`), {
      telemetry,
    });
  }
}
 
export async function runModificationSuggesters(
  patternMap: APPPatternMap,
  vckbDocuments: VCKBDocument[],
  modelCount: number = 3,
  client: ModelClient = defaultModelClient,
  opts?: { timeoutMs?: number },
): Promise<{
  modifications: APPModificationSuggestion[];
  telemetry: APPTelemetryEvent[];
}> {
  const slmStart = new Date().toISOString();
  const vckbContext = buildVCKBContext(vckbDocuments, [...APP_SLM_DOC_IDS]);
 
  const patternMapPayload = {
    substrate: patternMap.substrate,
    recurringPatterns: patternMap.recurringPatterns,
    stabilityMechanisms: patternMap.stabilityMechanisms,
    desiredAttractor: patternMap.desiredAttractor,
    analysisNotes: patternMap.analysisNotes,
  };
 
  const problemStatement = JSON.stringify({
    type: 'APP_PATTERN_MAP',
    patternMap: patternMapPayload,
  });
 
  const tasks = Array.from({ length: modelCount }, (_, i) => {
    const event: APPTelemetryEvent = {
      step: 'B_MODIFICATION_SUGGESTER',
      model: `SLM_${i + 1}`,
      startedAt: slmStart,
      status: 'STARTED',
    };
 
    return (async () => {
      try {
        const modelResponse = await client.run(
          {
            lane: 'APP_L1',
            capability: 'SLM_MOD_SUGGESTER',
            problemStatement,
            vckbContext,
            modelHint: 'cheap_slm',
          },
          opts?.timeoutMs,
        );
 
        event.tokensUsed = modelResponse.tokensUsed;
        event.model = modelResponse.modelId;
 
        const parsed = safeParseJSON(modelResponse.rawText, 'SLM_MOD_SUGGESTER');
        const parsedArray = Array.isArray(parsed) ? parsed : [parsed];
 
        const localSuggestions: APPModificationSuggestion[] = [];
        let invalidCount = 0;
        for (let index = 0; index < parsedArray.length; index++) {
          try {
            localSuggestions.push(
              validateModificationSuggestion(parsedArray[index], modelResponse.modelId, index),
            );
          } catch (_itemErr) {
            invalidCount += 1;
          }
        }
 
        event.completedAt = new Date().toISOString();
        event.status = 'COMPLETED';
        event.notes =
          invalidCount > 0
            ? `SLM generated ${localSuggestions.length} valid suggestions; rejected ${invalidCount}`
            : 'SLM modification suggestions generated';
 
        return { event, suggestions: localSuggestions };
      } catch (err) {
        event.completedAt = new Date().toISOString();
        event.status = 'FAILED';
        event.notes = `SLM error: ${err instanceof Error ? err.message : String(err)}`;
        return { event, suggestions: [] as APPModificationSuggestion[] };
      }
    })();
  });
 
  const results = await Promise.allSettled(tasks);
  const telemetry: APPTelemetryEvent[] = [];
  const allSuggestions: APPModificationSuggestion[] = [];
 
  for (const result of results) {
    if (result.status === 'fulfilled') {
      telemetry.push(result.value.event);
      allSuggestions.push(...result.value.suggestions);
    } else {
      telemetry.push({
        step: 'B_MODIFICATION_SUGGESTER',
        model: 'unknown',
        startedAt: slmStart,
        completedAt: new Date().toISOString(),
        status: 'FAILED',
        notes: `Promise rejection: ${String(result.reason)}`,
      });
    }
  }
 
  return { modifications: allSuggestions, telemetry };
}
 
export interface APPDREContext {
  runId: string;
  envelopeId?: string;
