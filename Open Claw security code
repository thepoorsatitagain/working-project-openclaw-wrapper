import * as fs from 'fs';
import * as path from 'path';
 
export interface VCKBDocument {
  id:        string;
  filename:  string;
  content:   string;
  version:   string;
  loadedAt:  string;
  byteSize:  number;
}
 
export interface VCKBLoadResult {
  documents:    VCKBDocument[];
  loadedCount:  number;
  failedCount:  number;
  errors:       string[];
}
 
const VCKB_DOCS_PATH = process.env.VCKB_DOCS_PATH
  ?? path.join(__dirname, '../../vckb/docs');
 
// -----------------------------------------------------------------------------
// Document registry.
// critical: true  = system degrades and APP pipeline is blocked if missing
// critical: false = logged warning only, system continues
//
// CONSTITUTIONAL_MASTER_OUTLINE_V3_0.md IS in the shipped archive — critical: true.
// V3.0 is the active constitutional document. V1 and V2 are in prior_archive/constitutional_history.zip.
// APP paper and patents are not yet converted — critical: false until added.
// This makes the shipped archive actually load without errors.
// -----------------------------------------------------------------------------
const EXPECTED_DOCUMENTS = [
  {
    id:       'CONSTITUTION',
    filename: 'CONSTITUTIONAL_MASTER_OUTLINE_V3_0.md',
    critical: true,
    note:     'Definitions, invariants, spine — authoritative governance doc',
  },
  {
    id:       'PATTERN_LIB',
    filename: 'pattern_library.json',
    critical: false,
    note:     'Growing decision memory — empty on first run',
  },
  {
    id:       'APP_PAPER',
    filename: 'APP_paper.md',
    critical: false,
    note:     'NEEDED: convert Applied_Pattern_Physics.docx to markdown',
  },
  {
    id:       'PATENT_1',
    filename: 'patent_ai_control_1.md',
    critical: false,
    note:     'NEEDED: convert patent_ai_control_1 source to markdown',
  },
  {
    id:       'PATENT_2',
    filename: 'patent_ai_control_2.md',
    critical: false,
    note:     'NEEDED: convert patent_ai_control_2 source to markdown',
  },
];
 
export function loadVCKBDocuments(): VCKBLoadResult {
  const result: VCKBLoadResult = {
    documents:   [],
    loadedCount: 0,
    failedCount: 0,
    errors:      [],
  };
 
  for (const expected of EXPECTED_DOCUMENTS) {
    const filePath = path.join(VCKB_DOCS_PATH, expected.filename);
 
    try {
      if (!fs.existsSync(filePath)) {
        const msg = `VCKB document missing: ${expected.filename} — ${expected.note}`;
        result.errors.push(msg);
        result.failedCount++;
        if (expected.critical) {
          console.warn(`[VCKB] CRITICAL MISSING: ${msg}`);
        } else {
          console.log(`[VCKB] NEEDED (not blocking): ${expected.filename}`);
        }
        continue;
      }
 
      const content = fs.readFileSync(filePath, 'utf-8');
      const stats   = fs.statSync(filePath);
 
      result.documents.push({
        id:       expected.id,
        filename: expected.filename,
        content,
        version:  '1.0.0',
        loadedAt: new Date().toISOString(),
        byteSize: stats.size,
      });
 
      result.loadedCount++;
      console.log(`[VCKB] Loaded: ${expected.filename} (${stats.size} bytes)`);
 
    } catch (err) {
      const msg = `Failed to read ${expected.filename}: ${(err as Error).message}`;
      result.errors.push(msg);
      result.failedCount++;
    }
  }
 
  return result;
}
 
export function getDocument(documents: VCKBDocument[], id: string): VCKBDocument | null {
  return documents.find(d => d.id === id) ?? null;
}
 
export function buildVCKBContext(documents: VCKBDocument[], docIds?: string[]): string {
  const selected = docIds
    ? documents.filter(d => docIds.includes(d.id))
    : documents;
 
  if (selected.length === 0) {
    return '[VCKB CONTEXT: NO DOCUMENTS LOADED — OUTPUTS MUST BE TREATED AS UNVERIFIED]';
  }
 
  const parts = selected.map(doc => `
=== VCKB DOCUMENT: ${doc.id} ===
Filename: ${doc.filename}
Version:  ${doc.version}
Loaded:   ${doc.loadedAt}
---
${doc.content}
=== END VCKB DOCUMENT: ${doc.id} ===
`);
 
  return [
    '=' .repeat(80),
    'AUTHORITATIVE VCKB CONTEXT — Version-Controlled Knowledge Base',
    `Documents in this context: ${selected.length}`,
    'These documents are the ONLY authoritative source of truth.',
    'Model outputs MUST be consistent with this content.',
    '=' .repeat(80),
    ...parts,
    '=' .repeat(80),
    'END VCKB CONTEXT',
    '=' .repeat(80),
  ].join('\n');
}
 
// Critical = CONSTITUTION must be present.
// APP paper and patents are needed for full pipeline but not blocking basic ops.
export function areCriticalDocumentsLoaded(documents: VCKBDocument[]): boolean {
  const criticalIds = EXPECTED_DOCUMENTS
    .filter(e => e.critical)
    .map(e => e.id);
  return criticalIds.every(id => documents.some(d => d.id === id));
}
 
// Full pipeline readiness: all five docs present
export function isFullPipelineReady(documents: VCKBDocument[]): boolean {
  return EXPECTED_DOCUMENTS.every(e => documents.some(d => d.id === e.id));
}
 
