import { Decision, DlcCapability, EnforcementInput } from './types';
 
export function decideEgress(
  input: EnforcementInput,
  dlc: DlcCapability,
  defaultAllowedHosts: string[] = []
): Decision {
  const method = input.method.toUpperCase();
  const host = normalizeHost(input.destinationHost);
 
  if (!dlc.allowedOperations.includes(input.operation)) {
    return deny('DLC-OP-001', `Operation ${input.operation} not allowed by DLC`);
  }
 
  if (!dlc.allowedMethods.includes(method)) {
    return deny('DLC-METHOD-001', `Method ${method} not allowed by DLC`);
  }
 
  const allowedHosts = new Set([
    ...defaultAllowedHosts.map(normalizeHost),
    ...dlc.allowedHosts.map(normalizeHost)
  ]);
 
  if (![...allowedHosts].some((pattern) => hostMatches(pattern, host))) {
    return deny('DLC-HOST-001', `Destination ${host} not allowed by DLC`);
  }
 
  if (input.path && dlc.pathPrefixes && dlc.pathPrefixes.length > 0) {
    const matched = dlc.pathPrefixes.some((prefix) => input.path!.startsWith(prefix));
    if (!matched) {
      return deny('DLC-PATH-001', `Path ${input.path} not allowed by DLC`);
    }
  }
 
  return {
    effect: 'ALLOW',
    reason: 'DLC authorizes outbound request',
    ruleId: 'DLC-ALLOW-001',
    dlc
  };
}
 
function deny(ruleId: string, reason: string): Decision {
  return { effect: 'DENY', reason, ruleId };
}
 
function normalizeHost(host: string): string {
  return host.trim().toLowerCase().replace(/\.$/, '');
}
 
function hostMatches(pattern: string, host: string): boolean {
  if (pattern === host) return true;
  if (pattern.startsWith('*.')) {
    const suffix = pattern.slice(1); // keep leading dot
    return host.endsWith(suffix) && host !== suffix.slice(1);
  }
  return false;
}
 
