    destinationHost: required('ENVELOPE_DESTINATION_HOST'),
    destinationPort: parseInt(required('ENVELOPE_DESTINATION_PORT', '443'), 10),
    method: required('ENVELOPE_METHOD', 'POST').toUpperCase(),
    operation: required('ENVELOPE_OPERATION', 'http_forward'),
    path: process.env.ENVELOPE_PATH
  };
 
