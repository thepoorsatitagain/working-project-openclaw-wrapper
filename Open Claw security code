    timeoutMs: process.env.DISPATCH_TIMEOUT_MS ? parseInt(process.env.DISPATCH_TIMEOUT_MS, 10) : 15000,
    rejectUnauthorized: process.env.DISPATCH_REJECT_UNAUTHORIZED === 'false' ? false : true
  });
 
