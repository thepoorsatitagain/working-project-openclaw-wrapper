// =============================================================================
// HYDRA KERNEL — APP Pipeline
// Version: 0.2.2
//
// Integrated state:
// - Step A: FM1 Pattern Mapper via provider-agnostic ModelClient
// - Step B: parallel SLM suggestion generation with validation
// - DRE append-only logging helpers for APP runs
// - FM2 / Review / Human interface / Pattern library update remain pending
// =============================================================================
 
import * as fs from 'fs';
import * as path from 'path';
import { VCKBDocument, buildVCKBContext } from './vckb_loader';
 
export type ModelLane = 'APP_L1';
 
export type ModelCapability =
  | 'FM1_PATTERN_MAPPER'
  | 'SLM_MOD_SUGGESTER';
 
export interface ModelRequest {
  lane: ModelLane;
  capability: ModelCapability;
  problemStatement: string;
  vckbContext: string;
  modelHint?: string;
}
 
export interface ModelResponse {
  rawText: string;
  modelId: string;
  tokensUsed?: number;
}
 
export interface ModelClient {
  run(request: ModelRequest, timeoutMs?: number): Promise<ModelResponse>;
}
 
const MODEL_ENDPOINT =
  process.env.GEL_MODEL_ENDPOINT ?? 'http://localhost:4000/model';
 
async function fetchWithTimeout(
  url: string,
  options: RequestInit,
  timeoutMs: number,
): Promise<Response> {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), timeoutMs);
  try {
    return await fetch(url, { ...options, signal: controller.signal });
  } finally {
    clearTimeout(timer);
  }
}
 
export class HttpModelClient implements ModelClient {
  async run(req: ModelRequest, timeoutMs: number = 20_000): Promise<ModelResponse> {
    const body = JSON.stringify(req);
 
    let response: Response;
    try {
      response = await fetchWithTimeout(
        MODEL_ENDPOINT,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body,
        },
        timeoutMs,
      );
    } catch (err) {
      const message = err instanceof Error ? err.message : String(err);
      if (message.toLowerCase().includes('abort')) {
        throw new Error(`Model endpoint timeout after ${timeoutMs}ms`);
      }
      throw new Error(`Model endpoint transport error: ${message}`);
    }
 
    if (!response.ok) {
      const text = await response.text().catch(() => '');
      throw new Error(`Model endpoint error: ${response.status} ${text}`.trim());
    }
 
    const json = (await response.json()) as {
      text: string;
      modelId?: string;
      tokensUsed?: number;
    };
 
    return {
      rawText: json.text,
      modelId: json.modelId ?? req.modelHint ?? 'unknown',
      tokensUsed: json.tokensUsed,
    };
  }
}
 
