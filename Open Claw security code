// =============================================================================
// HYDRA KERNEL — Dispatch Bridge (GEL → EGL credential minting)
// Version: 0.8.0
//
// Mints DLC tokens and GEL envelopes at GEL dispatch time so that
// OpenClaw carries signed credentials when it makes outbound calls
// through EGL.
//
// NOTE: This module signs independently. It does NOT import from
// current/egl/. GEL and EGL are separate npm packages. Invariant: no
// cross-package imports between GEL and EGL.
// =============================================================================
 
import { createHmac, createPrivateKey, randomUUID, sign } from 'crypto';
import * as fs from 'fs';
 
const DLC_PRIVATE_KEY_FILE = process.env.GEL_DLC_PRIVATE_KEY_FILE ?? '';
const DLC_SIGNING_SECRET   = process.env.GEL_DLC_SIGNING_SECRET   ?? '';
const ENV_PRIVATE_KEY_FILE = process.env.GEL_ENV_PRIVATE_KEY_FILE ?? '';
const ENV_SIGNING_SECRET   = process.env.GEL_ENV_SIGNING_SECRET   ?? '';
const DLC_TTL_SECS         = parseInt(process.env.GEL_DLC_TTL_SECS ?? '300', 10);
const OPENCLAW_MODEL        = process.env.OPENCLAW_MODEL    ?? 'claude-sonnet-4-20250514';
const OPENCLAW_PROVIDER     = process.env.OPENCLAW_PROVIDER ?? 'anthropic';
const EGL_ALLOWED_HOSTS     = (process.env.EGL_ALLOWED_HOSTS
  ?? 'api.anthropic.com,api.openai.com,api.groq.com')
  .split(',').map(h => h.trim()).filter(Boolean);
 
function b64url(buf: Buffer): string {
  return buf.toString('base64').replace(/=/g, '').replace(/\+/g, '-').replace(/\//g, '_');
}
function encode(obj: object): string {
  return b64url(Buffer.from(JSON.stringify(obj)));
}
function hmacSign(input: string, secret: string): string {
  return b64url(createHmac('sha256', secret).update(input).digest());
}
function ed25519Sign(input: string, pemPath: string): string {
  const pem = fs.readFileSync(pemPath, 'utf8');
  return b64url(sign(null, Buffer.from(input), createPrivateKey(pem)));
}
function makeToken(header: object, payload: object, keyFile: string, secret: string): string {
  const alg = keyFile ? 'EdDSA' : 'HS256';
  const h = encode({ ...header, alg });
  const p = encode(payload);
  const input = `${h}.${p}`;
  const sig = keyFile
    ? ed25519Sign(input, keyFile)
    : secret
      ? hmacSign(input, secret)
      : b64url(Buffer.from('dev-unsigned'));
  return `${input}.${sig}`;
}
 
export interface BridgeCredentials {
  dlcToken:      string;
  envelopeToken: string;
  jti:           string;
  envelopeId:    string;
}
 
export function mintBridgeCredentials(opts: {
  requestId: string;
  method:    string;
  path:      string;
}): BridgeCredentials {
  const now   = Math.floor(Date.now() / 1000);
  const jti   = randomUUID();
  const envId = randomUUID();
 
  const dlcToken = makeToken(
    { typ: 'DLC' },
    {
      version:           1,
      jti,
      subject:           'openclaw-agent',
      entityId:          'hydra-gel',
      entityRole:        'operator',
      modelId:           OPENCLAW_MODEL,
      provider:          OPENCLAW_PROVIDER,
      governanceProfile: 'gel-issued',
      allowedHosts:      EGL_ALLOWED_HOSTS,
      allowedMethods:    ['GET', 'POST', 'CONNECT'],
      allowedOperations: ['http_forward', 'https_connect'],
      iat: now, nbf: now, exp: now + DLC_TTL_SECS,
    },
    DLC_PRIVATE_KEY_FILE,
    DLC_SIGNING_SECRET,
  );
 
  const createdAt    = new Date().toISOString();
  const expiresAt    = new Date(Date.now() + 60_000).toISOString();
  const envelopeToken = makeToken(
    { typ: 'HYDRA_ENVELOPE' },
    {
      requestId:       envId,
      operation:       'PROXY_TO_OPENCLAW',
      destinationHost: 'localhost',
      destinationPort: 3000,
      method:          opts.method.toUpperCase(),
      path:            opts.path,
