import { decideEgress } from './policy';
import { DlcCapability, Effect, EnforcementInput, EnvelopeClaim, TelemetryRecord } from './types';
 
export interface ReplayFinding {
  level: 'INFO' | 'WARN' | 'ERROR';
  code: string;
  message: string;
}
 
export interface ReplayEntryReport {
  requestId: string;
  status: 'PASS' | 'FAIL' | 'INCOMPLETE';
  recordedOutcome?: Effect;
  recomputedOutcome?: Effect;
  findings: ReplayFinding[];
  input?: EnforcementInput;
  phases: string[];
}
 
export interface ReplayReport {
  generatedAt: string;
  totals: {
    requests: number;
    pass: number;
    fail: number;
    incomplete: number;
  };
  entries: ReplayEntryReport[];
}
 
interface SanitizedDecisionDetail {
  path?: string;
  envelopeRequestId?: string;
  envelopeClaim?: EnvelopeClaim;
  dlcScope?: DlcCapability;
}
 
function parseDecisionDetail(detail: Record<string, unknown> | undefined): SanitizedDecisionDetail {
  return (detail ?? {}) as unknown as SanitizedDecisionDetail;
}
 
function parseRequestInput(record: TelemetryRecord | undefined): EnforcementInput | undefined {
  if (!record?.destinationHost || !record.destinationPort || !record.method || !record.operation) {
    return undefined;
  }
  return {
    destinationHost: record.destinationHost,
    destinationPort: record.destinationPort,
    method: record.method,
    operation: record.operation,
    path: typeof record.detail?.path === 'string' ? record.detail.path : undefined
  };
}
 
function envelopeMatches(claim: EnvelopeClaim, input: EnforcementInput, dlc?: DlcCapability): string | null {
  if (claim.destinationHost !== input.destinationHost) return 'Envelope host mismatch';
  if (claim.destinationPort !== input.destinationPort) return 'Envelope port mismatch';
  if (claim.method.toUpperCase() !== input.method.toUpperCase()) return 'Envelope method mismatch';
  if (claim.operation !== input.operation) return 'Envelope operation mismatch';
  if ((claim.path ?? '') !== (input.path ?? '')) return 'Envelope path mismatch';
  if (dlc) {
    if (claim.dlcJti && claim.dlcJti !== dlc.jti) return 'Envelope DLC binding mismatch';
    if (claim.entityId && claim.entityId !== dlc.entityId) return 'Envelope entity binding mismatch';
    if (claim.subject && claim.subject !== dlc.subject) return 'Envelope subject binding mismatch';
  }
  return null;
}
 
function addFinding(report: ReplayEntryReport, level: 'INFO' | 'WARN' | 'ERROR', code: string, message: string): void {
  report.findings.push({ level, code, message });
  if (level === 'ERROR') {
    report.status = 'FAIL';
  } else if (level === 'WARN' && report.status === 'PASS') {
    report.status = 'INCOMPLETE';
  }
}
 
export function replayTelemetry(
  records: TelemetryRecord[],
  defaultAllowedHosts: string[] = []
): ReplayReport {
  const grouped = new Map<string, TelemetryRecord[]>();
  for (const record of records) {
    const key = record.requestId;
    const list = grouped.get(key) ?? [];
    list.push(record);
    grouped.set(key, list);
  }
 
  const envelopeUse = new Map<string, string[]>();
  const entries: ReplayEntryReport[] = [];
 
  for (const [requestId, group] of grouped.entries()) {
    group.sort((a, b) => a.timestamp.localeCompare(b.timestamp));
    const phases = group.map((item) => item.phase);
    const report: ReplayEntryReport = {
      requestId,
      status: 'PASS',
      recordedOutcome: group.find((item) => item.phase === 'DECISION')?.outcome,
      findings: [],
      phases,
      input: parseRequestInput(group.find((item) => item.phase === 'REQUEST'))
    };
 
    const decisionEvent = group.find((item) => item.phase === 'DECISION');
    const forwardEvent = group.find((item) => item.phase === 'FORWARD');
    const errorEvent = group.find((item) => item.phase === 'ERROR');
 
    if (!report.input) {
      report.status = 'INCOMPLETE';
      addFinding(report, 'WARN', 'REQ-001', 'Missing or incomplete REQUEST event');
    }
 
    if (!decisionEvent || !decisionEvent.outcome) {
      report.status = 'INCOMPLETE';
      addFinding(report, 'WARN', 'DEC-001', 'Missing or incomplete DECISION event');
    }
 
    if (decisionEvent && report.input) {
      const detail = parseDecisionDetail(decisionEvent.detail);
      const dlc = detail.dlcScope;
      const envelopeClaim = detail.envelopeClaim;
 
      if (!dlc) {
        addFinding(report, 'WARN', 'DLC-REPLAY-001', 'No DLC scope captured in telemetry; cannot fully recompute policy');
      } else {
        const recomputed = decideEgress(report.input, dlc, defaultAllowedHosts);
        report.recomputedOutcome = recomputed.effect;
        if (decisionEvent.outcome !== recomputed.effect) {
          addFinding(report, 'ERROR', 'DLC-REPLAY-002', `Recorded outcome ${decisionEvent.outcome} disagrees with recomputed outcome ${recomputed.effect}`);
        }
        if (decisionEvent.ruleId && decisionEvent.ruleId !== recomputed.ruleId) {
          addFinding(report, 'ERROR', 'DLC-REPLAY-003', `Recorded rule ${decisionEvent.ruleId} disagrees with recomputed rule ${recomputed.ruleId}`);
        }
 
        const decisionAt = new Date(decisionEvent.timestamp).getTime();
        if (dlc.nbf * 1000 > decisionAt + 5000) {
          addFinding(report, 'ERROR', 'DLC-REPLAY-004', 'Decision recorded before DLC nbf');
        }
        if (dlc.exp * 1000 < decisionAt - 5000) {
          addFinding(report, 'ERROR', 'DLC-REPLAY-005', 'Decision recorded after DLC expiry');
        }
      }
 
      if (envelopeClaim) {
        const mismatch = envelopeMatches(envelopeClaim, report.input, dlc);
        if (mismatch) {
          addFinding(report, 'ERROR', 'ENV-REPLAY-001', mismatch);
        }
 
        const createdAt = new Date(envelopeClaim.createdAt).getTime();
        const expiresAt = new Date(envelopeClaim.expiresAt).getTime();
        const decisionAt = new Date(decisionEvent.timestamp).getTime();
        if (!(createdAt <= decisionAt && decisionAt <= expiresAt)) {
          addFinding(report, 'ERROR', 'ENV-REPLAY-002', 'Decision timestamp falls outside envelope lifetime');
        }
 
        const seen = envelopeUse.get(envelopeClaim.requestId) ?? [];
        seen.push(requestId);
        envelopeUse.set(envelopeClaim.requestId, seen);
      } else if (decisionEvent.outcome === 'ALLOW') {
        addFinding(report, 'WARN', 'ENV-REPLAY-003', 'ALLOW decision missing captured envelope claim');
      }
    }
 
    if (decisionEvent?.outcome === 'DENY' && forwardEvent) {
      addFinding(report, 'ERROR', 'FLOW-001', 'DENY decision should not have FORWARD event');
    }
 
    if (decisionEvent?.outcome === 'ALLOW' && !forwardEvent && !errorEvent) {
      addFinding(report, 'WARN', 'FLOW-002', 'ALLOW decision has no FORWARD or ERROR event');
    }
 
    entries.push(report);
  }
 
  for (const entry of entries) {
    const decisionEvent = grouped.get(entry.requestId)?.find((item) => item.phase === 'DECISION');
    const detail = parseDecisionDetail(decisionEvent?.detail);
    const envelopeRequestId = detail.envelopeClaim?.requestId;
    if (!envelopeRequestId) continue;
    const uses = envelopeUse.get(envelopeRequestId) ?? [];
    const uniqueUses = Array.from(new Set(uses));
    if (uniqueUses.length > 1) {
      addFinding(entry, 'ERROR', 'ENV-REPLAY-004', `Envelope requestId ${envelopeRequestId} reused across ${uniqueUses.length} requests`);
    }
  }
 
  const totals = {
    requests: entries.length,
    pass: entries.filter((entry) => entry.status === 'PASS').length,
    fail: entries.filter((entry) => entry.status === 'FAIL').length,
    incomplete: entries.filter((entry) => entry.status === 'INCOMPLETE').length
  };
 
  return {
    generatedAt: new Date().toISOString(),
    totals,
    entries: entries.sort((a, b) => a.requestId.localeCompare(b.requestId))
  };
}
 
