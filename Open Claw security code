import { GELRequest, PolicyRule } from './types';
 
// -----------------------------------------------------------------------------
// Operations — the explicit vocabulary of what the system can do.
// An envelope that does not contain an operation string cannot authorize it.
// -----------------------------------------------------------------------------
export const OPERATIONS = {
  HEALTH_CHECK:         'HEALTH_CHECK',
  TELEMETRY_READ:       'TELEMETRY_READ',
  APP_PIPELINE_SUBMIT:  'APP_PIPELINE_SUBMIT',
  PROXY_TO_OPENCLAW:    'PROXY_TO_OPENCLAW',
  VCKB_READ:            'VCKB_READ',
} as const;
 
// TTL constants
const TTL_SHORT  =  30_000;  // 30 seconds — internal endpoints
const TTL_MEDIUM =  60_000;  // 60 seconds — proxy requests
const TTL_LONG   = 120_000;  // 2 minutes  — pipeline submissions
 
// -----------------------------------------------------------------------------
// Policy Pack (Step 3)
// Rules evaluated in order. First match wins.
// If no rule matches: default DENY (Invariant 8).
// -----------------------------------------------------------------------------
const BASE_POLICY_PACK: PolicyRule[] = [
 
  // Rule GEL-001: Internal health check — always allowed, no model access
  {
    id: 'GEL-001',
    description: 'Internal GEL health check endpoint — no inference, no proxy',
    condition: (req) => req.path === '/gel/health' && req.method === 'GET',
    effect: 'ALLOW',
    grantedOperations: [OPERATIONS.HEALTH_CHECK],
    maxTokens: 0,
    ttlMs: TTL_SHORT,
  },
 
  // Rule GEL-002: Telemetry read — read-only audit access
  {
    id: 'GEL-002',
    description: 'Telemetry read endpoints — read-only, no inference',
    condition: (req) =>
      req.path.startsWith('/gel/telemetry') && req.method === 'GET',
    effect: 'ALLOW',
    grantedOperations: [OPERATIONS.TELEMETRY_READ],
    maxTokens: 0,
    ttlMs: TTL_SHORT,
  },
 
  // Rule GEL-003: VCKB status read
  {
    id: 'GEL-003',
    description: 'VCKB status endpoint — read-only',
    condition: (req) => req.path === '/gel/vckb' && req.method === 'GET',
    effect: 'ALLOW',
    grantedOperations: [OPERATIONS.VCKB_READ],
    maxTokens: 0,
    ttlMs: TTL_SHORT,
  },
 
  // Rule GEL-004: APP pipeline submission
  {
    id: 'GEL-004',
    description: 'APP pipeline problem submission — governed inference pathway',
    condition: (req) =>
      req.path === '/gel/app-pipeline' && req.method === 'POST',
    effect: 'ALLOW',
    grantedOperations: [OPERATIONS.APP_PIPELINE_SUBMIT, OPERATIONS.VCKB_READ],
    maxTokens: 2000,
    ttlMs: TTL_LONG,
  },
 
  // Rule GEL-006: Skill pre-authorization check (from hydra-gel OpenClaw skill)
  {
    id: 'GEL-006',
    description: 'OpenClaw hydra-gel skill pre-authorization — skill execution governance',
    condition: (req) =>
      (req.path === '/gel/skill-check' || req.path === '/gel/skill-complete') &&
      req.method === 'POST',
    effect: 'ALLOW',
    grantedOperations: [OPERATIONS.APP_PIPELINE_SUBMIT],
    maxTokens: 0,
    ttlMs: TTL_SHORT,
  },
 
  // Rule GEL-005: Proxy to OpenClaw — general inference requests
  // Only allows POST to known OpenClaw paths.
  // GET is not proxied — no read operations on the upstream model.
  {
    id: 'GEL-005',
    description: 'Proxy POST requests to OpenClaw inference engine',
    condition: (req) =>
      req.method === 'POST' &&
      !req.path.startsWith('/gel/'),
    effect: 'ALLOW',
    grantedOperations: [OPERATIONS.PROXY_TO_OPENCLAW],
    maxTokens: 1000,
    ttlMs: TTL_MEDIUM,
  },
 
  // Rule GEL-DENY-001: Explicit deny — GET requests to OpenClaw
  // The model should not be read from directly without governance.
  {
    id: 'GEL-DENY-001',
    description: 'Deny GET requests to upstream model — use governed endpoints',
    condition: (req) =>
      req.method === 'GET' && !req.path.startsWith('/gel/'),
    effect: 'DENY',
    grantedOperations: [],
  },
];
 
// -----------------------------------------------------------------------------
// Step 3: Load policies
// In the full implementation this reads from VCKB as signed AKMs.
// Currently returns base pack — real but not yet VCKB-sourced.
// -----------------------------------------------------------------------------
export function loadPolicies(): PolicyRule[] {
  return BASE_POLICY_PACK;
}
 
// -----------------------------------------------------------------------------
// Step 4: Evaluate policies — first match wins
// Returns the matched rule, the result, and the granted operations.
// Invariant 8: No match = DENY. Always.
// -----------------------------------------------------------------------------
export function evaluatePolicies(
  req: GELRequest,
  rules: PolicyRule[]
): { matched: PolicyRule | null; result: 'ALLOW' | 'DENY'; grantedOperations: string[] } {
  for (const rule of rules) {
    if (rule.condition(req)) {
      return {
        matched: rule,
        result: rule.effect,
        grantedOperations: rule.effect === 'ALLOW' ? rule.grantedOperations : [],
      };
    }
  }
  // Invariant 8: Fail closed. No match = DENY.
  return { matched: null, result: 'DENY', grantedOperations: [] };
}
 
